	background: $box-background;
	//Flex Setting *necessary due to dependency*
	.text-and-background-content {
		@if not $full-width {
			@include media-constructor(flex-basis, extend-constructor('calc(', $box-size , ' '), extend-constructor('- ', $margin-calculation, ')'));
		
			&:first-child {
				margin-left: $margin-calculation;
				margin-right: 0;
			
				> .inner {
					@include media-constructor(padding-right, 1rem);
				
					padding-left: 0;
				}
			
				@if $content-width-rem > $breakpoint-md {
					@media screen and (max-width: $content-width-rem) and (min-width: $breakpoint-md) {
						margin-left: 0;
						padding-left: 1rem;
					}
				}
			}
		
			margin-right: $margin-calculation;
			margin-left: 0;
		
			> .inner {
				@include media-constructor(padding-left, 1rem);
			
				padding-right: 0;
			}
		
			@media screen and(max-width: $breakpoint-md-max) {
				@include media-constructor(flex-basis, $box-size);
			
				&:first-child {
					margin-left: 0;
				
					> .inner {
						@include media-constructor(padding, $spacer);
					}
				}
			
				margin-right: 0;
			
				> .inner {
					@include media-constructor(padding, $spacer);
				}
			}
		
			@media screen and(max-width: $breakpoint-xs-max) {
				@include media-constructor(flex-basis, $box-size);
			
				>.inner {
					@include media-constructor(padding, $spacer);
				}
				&:first-child { margin-left: 0; }
			
				margin-right: 0;
			}
		}
	
		@else  {
			@include media-constructor(flex-basis, $box-size);
		
			> .inner {
				@include media-constructor(padding, $padding);
			}
		}
	
		@include preset-headline-color($background-check);
	
		&,
		.ed-element:not(.ed-button) > a { color: $text-color; }
	
		& a.inner { outline-offset: -3px; }
	}

	.text-and-background-background {
		& a.inner { outline-offset: -3px; }
	}
