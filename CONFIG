 * @Param("hover-duration", type="number",  visibility={"hover-style"={"rotate", "zoom", "fade", "captions"}}, options={"units"={"s"}}, group="gallery")
 * @Param("hover-opacity", type="number", visibility={"hover-style"={"rotate", "fade", "zoom"}}, options={"units"={"%"},"responsive"=1}, group="gallery")
 * @Param("hover-scale", type="number", visibility={"hover-style"={"rotate", "zoom"}}, options={"units"={"%"}, "responsive"=1}, group="gallery")
