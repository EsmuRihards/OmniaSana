	$input-placeholder: first-color($input-placeholder, $input-color);
	$input-background-hover: first-color($input-background-hover, $input-background-check);
	$input-color-hover: first-color($input-color-hover, $input-color,prioritize-color($color: $color-default, $background: $input-background-hover));
	$input-placeholder-hover: first-color($input-placeholder-hover, $input-placeholder, $input-color-hover);

	$border-color-hover: first-color($border-color-hover, $border-color-primary);

	$input-background-focus: first-color($input-background-focus, $input-background-hover);
