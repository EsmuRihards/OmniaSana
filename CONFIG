 * @Param("icon-color", type="color", group="icon")
 * @Param("icon-size", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("icon-margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
*/
@mixin info-bar-v3(
	$background: $color-primary, 
	$padding: (0.5rem 1rem 0.5rem 1rem, null, null), 
	$margin: 1rem, 
	$color: none, 
	$info-bar-font-size: 1rem, 
	$icon-color: $color, 
	$icon-size: $info-bar-font-size, 
	$icon-margin: 0.6rem
) {
	$background: first-color($background, preset-accent-color($color-background));
	$icon-color: first-color($icon-color, preset-text-color($background));
	$color: first-color($color, preset-text-color($background));

	background: $background;

	> .inner {
		@include media-constructor(padding, $padding);
	
		> .info-bar-content {
			flex-basis: auto;
		
			&:not(:last-child) {
				@include media-constructor(margin-right, $margin);
			}
		
			&,
			a,
			a:hover { color: $color; }
		
			.ed-text {
				flex-basis: auto;
			
				@include media-constructor(font-size, $info-bar-font-size);
			}
		
			// :not necessary if you want to combine social icon preset and Info-bar, otherwise the social icons will also be manipulated
			.ed-icon:not(.social-icons-icon) {
				flex: 0 1 auto;
				line-height: normal;
				display: flex;
			
				i,
				svg:not(.social-icons-icon) {
					fill: $icon-color !important;
					color: $icon-color;
					vertical-align: baseline;
				
					@include media-constructor(margin-right, $icon-margin);
					@include media-constructor(max-height, $icon-size);
					@include media-constructor(width, $icon-size);
				}
			}
		}
	}
}

