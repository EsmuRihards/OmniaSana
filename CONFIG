 * @Param("width", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="logos")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1, "separator"=1}, group="logos")
 * @Param("border-style-primary", type="choice", options={"choices"={"none","solid", "dashed", "dotted", "double"}, "expanded"=1}, group="logos")
 * @Param("border-width-primary", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, type="spacing", options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="logos")
 * @Param("border-color-primary", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, type="color", group="logos")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="logos")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="logos")
 */
@mixin marquee-v2(
	$speed: 5%, 
	$disable-on-mobile: false, 
	$background: $color-background, 
	$aspect-ratio: 16/9, 
	$logo-max-height: 70%, 
	$logo-max-width: 70%, 
	$width: 15rem, 
	$margin: 1rem, 
	$border-style-primary: solid, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-default, 
	$border-radius-primary: 0, 
	$box-shadow-primary: none
) {
	$width-lg: nth(inherit-list($width),1);
	$width-md: nth(inherit-list($width),2);
	$width-xs: nth(inherit-list($width),3);

	$margin-lg: nth(inherit-list($margin),1);
	$margin-md: nth(inherit-list($margin),2);
	$margin-xs: nth(inherit-list($margin),3);

	$speed-lg: nth(inherit-list($speed),1);
	$speed-md: nth(inherit-list($speed),2);
	$speed-xs: nth(inherit-list($speed),3);

	$mobile-disabled-min: 0;
	$mobile-disabled-max: 0;

	@if $disable-on-mobile == true {
		$mobile-disabled-min: $breakpoint-xs;
		$mobile-disabled-max: $breakpoint-xs-max;
	}

	> .inner {
		@include media-constructor(
			padding-left, 
			extend-constructor("calc(",$spacer," -"), extend-constructor("",$margin," /2)"), 
			
		);
		@include media-constructor(
			padding-right, 
			extend-constructor("calc(",$spacer," -"),     		extend-constructor("",$margin," /2)"), 
			
		);
	
		@media screen and (min-width: $mobile-disabled-min) {
			body:not(.edit) & {
				@include media-constructor(height, extend-constructor("calc(",$spacer-container-all," * 2 +"), extend-constructor("",$width," - "),extend-constructor("",$margin,")"));
			}
		}
		@media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
			body:not(.edit) & { height: auto; }
		}
	}

	//FIX for Overflow - needable in this case
	&.wv-boxed > .inner { overflow: hidden; }

	// Fixes bug caused by max-width:100%;
	&,
	.ed-container { max-width: none; }

	.ed-container & {
		> .inner {
			padding: 0;
			width: auto;
		
			@include media-constructor(margin, extend-constructor("calc( -1 * ",$margin,")"));
		
			@media screen and (min-width: $mobile-disabled-min) {
				body:not(.edit) & { height: $width-lg; }
			}
			@media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
				body:not(.edit) & { height: auto; }
			}
		}
	}

	.marquee-wrap {
		> .inner {
			align-content: stretch;
			align-items: stretch;
		
			@media screen and (max-width: $mobile-disabled-max), (-ms-high-contrast: active), (-ms-high-contrast: none) {
				justify-content: center;
			}
		}
	
		body:not(.edit) & {
			@media screen and (min-width: $mobile-disabled-min), (-ms-high-contrast: active), (-ms-high-contrast: none) {
				@supports (display: grid) {
					position: absolute;
					top: 50%;
					animation: marquee-animation linear infinite;
					// Large devices
					@for $i from 1 through 50 {
						$marquee-width: ($i * (nth($width-lg, 1) / 1rem) + ($i * (nth($margin-lg, 1) / 1rem) - 1));
					
						&[data-items="#{$i}"] {
							$s: strip-units($marquee-width) / strip-units(nth($speed-lg, 1));
						
							animation-duration: #{$s}s;
						}
					}
				
					// Medium devices
					@media screen and (max-width: $breakpoint-md-max) {
						@for $i from 1 through 50 {
							$marquee-width: ($i * (nth($width-md, 1) / 1rem) + ($i * (nth($margin-md, 1) / 1rem) - 1));
						
							&[data-items="#{$i}"] {
								$s: strip-units($marquee-width) / strip-units(nth($speed-md, 1));
							
								animation-duration: #{$s}s;
							}
						}
					}
				
					// Small devices
					@media screen and (max-width: $breakpoint-xs-max) {
						@for $i from 1 through 50 {
							$marquee-width: ($i * (nth($width-xs, 1) / 1rem) + ($i * (nth($margin-xs, 1) / 1rem) - 1));
						
							&[data-items="#{$i}"] {
								$s: strip-units($marquee-width) / strip-units(nth($speed-xs, 1));
							
								animation-duration: #{$s}s;
							}
						}
					}
				
					> .inner {
						width: auto;
						display: flex;
						flex-wrap: nowrap;
					}
				}
			}
		}
	}

	.marquee-wrap > .inner > * {
		position: relative;
	
		@include media-constructor(width, $width);
		@include media-constructor(flex-basis, $width);
		@include media-constructor(margin, extend-constructor('calc(',$margin,' /2)'));
	
		//@include media-constructor(padding-bottom, extend-constructor("calc(1 / (",$aspect-ratio,") *"),     		extend-constructor("",$width," -"),     		extend-constructor("",$margin," * 2)"));
		@include media-constructor(padding-bottom, extend-constructor("calc(1 / (",$aspect-ratio,") *"), extend-constructor("",$width,")"));
	
		> * {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
		
			@include media-constructor(max-height, $logo-max-height);
			@include media-constructor(max-width, $logo-max-width);
		
			@media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
				text-align: center;
			
				img {
					@include media-constructor(max-height, $logo-max-height);
					@include media-constructor(max-width, $logo-max-width);
				}
			}
		}
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
	
		//Box shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		.edit & {
			counter-increment: slide;
			position: relative;
		
			&:before {
				position: absolute;
				z-index: 0;
				top: 0;
				left: -1px;
				content: "Marquee item " counter(slide);
				display: block;
				background: #f58220;
				color: #fff;
				padding: 4px;
				font-size: 12px;
				line-height: 1;
				font-family: Helvetica, sans-serif;
				opacity: 0.75;
			}
		
			&:hover:before { display: none; }
		}
	}

	.marquee-item { background: $background; }

	@keyframes marquee-animation {
		0% {
			left: 0;
			transform: translate(0, -50%);
		}
	
		50% {
			left: 100%;
			transform: translate(-100%, -50%);
		}
	
		100% {
			left: 0;
			transform: translate(0, -50%);
		}
	}
}

/**
*
* @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
* @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
* @Param("margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="layout")
* @Param("margin-horizontal", type="bool", group="layout")
* @Param("aspect-ratio", type="choice", options={"choices"={"1/2", "1/1", "2/1", "4/3", "16/9", "16/10"}, "responsive"=1, "expanded"=1}, group="layout")
* @Param("logo-max-width", type="number", options={"units"={"%"}, "responsive"=1, "width"=50}, group="layout")
* @Param("logo-max-height", type="number", options={"units"={"%"}, "responsive"=1, "width"=50}, group="layout")
* @Param("box-background", type="color", group="box")
* @Param("box-border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
* @Param("box-border-width", type="spacing", visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("box-border-color", type="color", visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
* @Param("box-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
*/
@mixin partners-v3(
	$columns: 3 null 1, 
	$grow: false, 
	$margin: 2rem, 
	$margin-horizontal: false, 
	$aspect-ratio: 16/9, 
	$logo-max-width: 70%, 
	$logo-max-height: 70%, 
	$box-background: none, 
	$box-border-style: solid, 
	$box-border-width: 1px, 
	$box-border-color: $color-default, 
	$box-border-radius: 0, 
	$box-shadow-primary: none
) {
	$background-check: first-color($logo-background, $color-background);
	$text-color: preset-text-color($background-check);

	$columns-lg: nth(inherit-list($columns),1);
	$columns-md: nth(inherit-list($columns),2);
	$columns-xs: nth(inherit-list($columns),3);

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive:true
	);

	// IE 11 image marign bug fix 
	@media screen and (-ms-high-contrast:active),(-ms-high-contrast:none) and (min-width: $breakpoint-md) {
		> .inner { min-height: 1%; }
	}

	> .inner > .ed-image,
	> .inner > .ed-text {
		position: relative;
		// Background
		@if type-of($box-background) == color and $box-background != none {
			background: $box-background;
		
			@include preset-headline-color($background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $box-border-width);
	
		border: {
			style: $box-border-style;
			color: $box-border-color;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $box-border-radius);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		// Keep aspect ratio through padding (https://www.w3schools.com/howto/howto_css_aspect_ratio.asp)  // We cannot work with percent for the aspect ratio (https://stackoverflow.com/a/33503864)
		@include media-constructor(padding-bottom, extend-constructor("calc(1 / (",$aspect-ratio,") *"), 	    	extend-constructor("(100% / ",$columns,") -"),     		 		    extend-constructor("",$margin,")"));
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		// Due to ensuring aspect ratio by padding, we need to position the image absolutely
		img,
		p {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
		
			@include media-constructor(max-height, $logo-max-height);
			@include media-constructor(max-width, $logo-max-width);
		}
	
		a {
			position: absolute;
			width: 100%;
			height: 100%;
			//Border Radius
			@include media-constructor(border-radius, $box-border-radius);
		}
	}
}

