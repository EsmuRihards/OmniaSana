/**
 * pricing-blocks is to show menu price at one side and other side will be the group title
 * Last Update: 2025-02-11T12:40:19+01:00
 * @Param("columns", type="choice", options={"choices"={"1", "2", "4", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")
 * @Param("reversed-box", type="bool", visibility={"columns"={"2", "4", "6"}}, group="layout")
 * @Param("box-background", type="color", group="box")
 * @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", options={"units"={"px", "rem", "vw", "vh"}, "responsive"=1}, visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box")
 * @Param("last-item-right", type="bool", group="table")
 * @Param("stripes", type="bool", group="table")
 * @Param("stripes-background", type="color", visibility={"stripes": true}, options={"width"=50}, group="table")
 * @Param("stripes-color", type="color", visibility={"stripes": true}, options={"width"=50}, group="table")
*/
@mixin pricing-blocks-v3(
	$columns: 2 null 1, 
	$margin: 1rem, 
	$margin-horizontal: false, 
	$reversed-box: true, 
	$box-background: none, 
	$box-padding: 1rem, 
	$border-style-primary: solid, 
	$border-width-primary: 1px, 
	$border-color-primary: rgba($color-secondary,.1), 
	$border-radius-primary: 0, 
	$box-shadow-primary: none, 
	$last-item-right: false, 
	$stripes: false, 
	$stripes-background: rgba($color-default,.3), 
	$stripes-color: none, 
	
) {
	$columns-lg: nth(inherit-list($columns),1);
	$columns-md: nth(inherit-list($columns),2);
	$columns-xs: nth(inherit-list($columns),3);

	//Colors

	$background-check: first-color($box-background, $color-background);
	$stripes-background-check: first-color($stripes-background,$background-check);
	$text-color: preset-text-color($background-check);
	$stripes-color: first-color($stripes-color, preset-text-color($stripes-background-check));

	@if $margin-horizontal {
		&:not(.wv-boxed)>.inner {
			padding: $margin;
			// calc for IE11, modern browsers width: auto
			width: calc(100% - 2 * #{nth(nth($margin,1), 1)});
			margin: nth(nth($margin, 1), 1) nth(nth($margin, 1), 1);
			// dont apply margin horizontal for breakpoint sm
		}
	}

	// remove padding left and right if element is inside another container (already set on parent)
	.ed-container &,
	.ed-reference-container &,
	.ed-collection-container &,
	.ed-collection-item & {
		>.inner {
			padding: 0;
			max-width: none;
		}
	}

	> .inner {
		display: grid;
	
		$grid-template-columns: inherit-list($columns);
		$grid-template-columns: (
						    	    repeat(nth($grid-template-columns,1), 1fr)
						    	    repeat(nth($grid-template-columns,2), 1fr)
						    	    repeat(nth($grid-template-columns,3), 1fr)
						    	);
	
		@include media-constructor(grid-template-columns, $grid-template-columns);
	
		align-items: stretch;
	
