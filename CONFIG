						@include media-constructor(padding, $spacer);
					}
					&:first-child { margin-left: 0; }
				
					margin-right: 0;
				}
			}
		
			@if $box-align-lg == "right" {
				&:first-child {
					margin-left: 0;
				
					> .inner {
						margin-right: $margin-calculation;
						margin-left: 0;
						padding-right: 0;
						width: auto;
					}
				}
			
				margin-left: $margin-calculation;
				margin-right: 0;
			
				> .inner {
					@include media-constructor(padding-left, 1rem);
				
					padding-right: 0;
				}
			
				@media screen and(max-width: $breakpoint-md-max) {
					@include media-constructor(flex-basis, $box-size);
				
					&:first-child {
						margin-right: 0;
					
						> .inner {
							@include media-constructor(padding, $spacer);
						
							margin-right: 0;
						}
					}
				
					margin-right: 0;
				
					> .inner {
						@include media-constructor(padding, $spacer);
					}
				}
			
				@media screen and(max-width: $breakpoint-xs-max) {
					@include media-constructor(flex-basis, $box-size);
				
					>.inner {
						@include media-constructor(padding, $spacer);
					}
					&:first-child { margin-right: 0; }
				
					margin-left: 0;
				}
			}
		}
	
		@else  {
			@include media-constructor(flex-basis, $box-size);
			@include media-constructor(margin, $box-margin);
		
			@if length($box-margin-lg) == 4 {
				@include media-constructor(max-width, extend-constructor('calc(100% - ', nth($box-margin-lg,2), ' -'), extend-constructor('', nth($box-margin-lg,4), ')'));
			}
			@else  {
				@include media-constructor(max-width, extend-constructor('calc(100% - 2 * ', $box-margin-lg, ')'));
			}
		
			@media screen and (max-width: $breakpoint-md-max) {
				@if length($box-margin-md) == 4 {
					@include media-constructor(max-width, extend-constructor('calc(100% - ', nth($box-margin-md,2), ' -'), extend-constructor('', nth($box-margin-md,4), ')'));
				}
				@else  {
					@include media-constructor(max-width, extend-constructor('calc(100% - 2 * ', $box-margin-md, ')'));
				}
			}
		
			@media screen and (max-width: $breakpoint-xs-max) {
				@if length($box-margin-xs) == 4 {
					@include media-constructor(max-width, extend-constructor('calc(100% - ', nth($box-margin-xs,2), ' -'), extend-constructor('', nth($box-margin-xs,4), ')'));
