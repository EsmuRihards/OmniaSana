/**
 * opening-hours: clock + fields for days in a week + extra fields to account for holidays
 * Last Update: 2022-06-03T15:35:31+02:00
 *
 * @Param("layout", type="choice", options={"choices"={"row", "column"}, "expanded"=1}, group="layout")
 * @Param("box-margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="layout")
 * @Param("box-background", type="color", group="box")
 * @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", options={"units"={"px", "rem", "vw", "vh"}, "responsive"=1}, visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("last-border", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, type="bool", group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
 * @Param("clock-color", type="color", group="icon")
 * @Param("clock-fz", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("clock-fixed", type="bool", group="icon")
 * @Param("clock-full-width", visibility={"clock-fixed": false}, type="bool", group="icon")
 * @Param("clock-box-style", type="bool", group="icon")
 * @Param("text-color", type="color", group="text")
 * @Param("text-fz-headline", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="text")
 * @Param("text-fz", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="text")
 */
@mixin opening-hours-v3(
	$layout: row, 
	$box-margin: 0rem, 
	$box-background: none, 
	$box-padding: 0.5rem, 
	$border-style-primary: none, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-primary, 
	$last-border: true, 
	$border-radius-primary: 0px, 
	$box-shadow-primary: none, 
	$clock-color: none, 
	$clock-fz: 2.63rem, 
	$clock-fixed: false, 
	$clock-full-width: false, 
	$clock-box-style: true, 
	$text-color: none, 
	$text-fz-headline: .815rem, 
	$text-fz: 0.9rem
) {
	//Responsive variables
	$box-margin-lg: nth(inherit-list($box-margin),1);
	$box-margin-md: nth(inherit-list($box-margin),2);
	$box-margin-xs: nth(inherit-list($box-margin),3);

	// Colors

	$background-check: first-color($box-background, $color-background);
	$box-background-check: first-color($box-background, $color-background);

	// If clock & text-color are not set, automatically calculate colors based on contrast
	$clock-color: first-color($clock-color,if(type-of($box-background) == color,preset-text-color($background-check),preset-accent-color($background-check)));
	$text-color: first-color($text-color,preset-text-color($background-check));
	$border-color-primary: first-color($border-color-primary,preset-text-color($background-check));

	@include flex-grid-row($margin: $box-margin, $responsive:true);

	position: relative;
	// DEFAULT HORIZONTAL LAYOUT
	.opening-hours-box,
	.opening-hours-clock {
		text-align: center;
		flex-basis: auto;
		align-items: center;
		align-content: center;
		justify-content: center;
		flex-flow: column wrap;
		background: $box-background;
		position: relative;
	
		@include media-constructor(margin, extend-constructor('calc(',$box-margin,' /2)'));
		@include media-constructor(padding, $box-padding);
	
		p {
			color: $text-color;
			margin-bottom: 0;
		
			@include media-constructor(font-size, $text-fz);
		
			strong {
				text-transform: uppercase;
				color: $text-color;
			
				@include media-constructor(font-size, $text-fz-headline);
			}
		}
	
		//Link Reset
		> a,
		> a:hover {
			text-decoration: none;
			color: unset;
		}
	
		//Background & Text Color
		@if type-of($box-background) == color and $box-background != none {
			background: $box-background;
		
			@include preset-headline-color($box-background-check);
		
			&,
			.ed-text a,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
	
		//Box-shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	}

	.opening-hours-clock {
		svg {
			fill: $clock-color;
		
			@include media-constructor(width, $clock-fz);
			@include media-constructor(height, $clock-fz);
		}
	}

	@if $layout == "row" {
		@if $clock-fixed == false and $clock-full-width {
			.opening-hours-clock { flex-basis: calc(100% - (2 * #{$box-margin-lg}) /2); }
		}
	
		@media screen and (max-width: $breakpoint-md-max) {
			flex-wrap: wrap;
			justify-content: center;
			align-items: center;
			align-content: center;
		
			.opening-hours-clock { flex-basis: calc(100% - (2 * #{$box-margin-md}) /2); }
		
			.opening-hours-box {
				flex-basis: calc(100% / 3 - (#{$box-margin-md} *2) /2);
				margin: calc(#{$box-margin-md} / 2);
			}
		}
	
		@media screen and (max-width: $breakpoint-xs-max) {
			>.inner { flex-direction: column; }
		
			.opening-hours-box {
				flex-basis: calc(100% - (#{$box-margin-xs} *2) /2);
				margin: calc(#{$box-margin-xs} / 2);
			}
		}
	}

	@if $layout == "column" {
		// VERTICAL LAYOUT
		>.inner {
			flex-direction: column;
		
			.opening-hours-box,
			.opening-hours-clock {
				@include media-constructor(flex-basis, extend-constructor('calc(100% - ',$box-margin,')'));
			}
		}
	}

	@if $clock-fixed and $layout == "column" or $clock-fixed and $layout == "row" {
		.opening-hours-clock { margin: 0; }
	}

	@if $clock-fixed {
		position: relative;
		overflow: visible;
	
		.opening-hours-clock {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%,-50%);
			pointer-events: none;
			flex-basis: 100%;
		}
	}

	@if $last-border == false {
		.opening-hours-box:last-child { border: none; }
	}
	@if $clock-box-style == false {
		.opening-hours-clock {
			border: 0;
			padding: 0;
			box-shadow: none;
			background: none;
		}
	}
}

/**
* Image accordion -  image and title coming with accordion
* Last Update: 2026-01-14T15:39:32+01:00
* 
* @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
* @Param("grow", type="bool", options={"responsive"=1}, group="layout")
* @Param("margin", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
* @Param("margin-horizontal", type="bool", group="layout")
* @Param("trigger-background", type="color", options={"width"=50}, group="image_trigger")
* @Param("trigger-background-active", type="color", options={"width"=50}, group="image_trigger")
* @Param("caption-height", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="image_trigger")
* @Param("trigger-border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="image_trigger")
* @Param("trigger-border-width", type="spacing", visibility={"trigger-border-style"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="image_trigger")
* @Param("trigger-border-color", type="color", visibility={"trigger-border-style"={"solid", "dashed", "dotted", "double"}}, options={"width"=50}, group="image_trigger")
* @Param("trigger-border-color-active", type="color", visibility={"trigger-border-style"={"solid", "dashed", "dotted", "double"}}, options={"width"=50}, group="image_trigger") 
* @Param("trigger-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="image_trigger")
* @Param("box-shadow-primary", type="shadow", options={"responsive"=1, "separator"=1}, group="image_trigger")  
* @Param("trigger-animation", type="choice", options={"choices"={"bottom", "top", "right", "left", "zoomIn", "zoomOut", "background", "grayscale", "blur", "shadow"}}, group="image_trigger")
* @Param("trigger-animation-duration", type="number", options={"units"={"s"}}, group="image_trigger")
* @Param("content-background", type="color-type-selector", group="content")
* @Param("content-padding", type="spacing", options={"units"={"none", "px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("content-border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="content")
* @Param("content-border-width", type="spacing", visibility={"content-border-style"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("content-border-color", type="color", visibility={"content-border-style"={"solid", "dashed", "dotted", "double"}}, group="content")
* @Param("content-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("box-shadow-secondary", type="shadow", options={"responsive"=1}, group="content") 
*/
@mixin image-accordion-v4(
	$columns: 3 null 1, 
	$grow: false, 
	$margin: 1rem, 
	$margin-horizontal: false, 
	$trigger-background: rgba($color-secondary,0.5), 
	$trigger-background-active: rgba($color-secondary,0.8), 
	$caption-height: 3rem, 
	$trigger-border-style: none, 
	$trigger-border-width: 1px, 
	$trigger-border-color: $color-secondary, 
	$trigger-border-color-active: $color-primary, 
	$trigger-border-radius: 0px, 
	$box-shadow-primary: none, 
	$trigger-animation: bottom, 
	$trigger-animation-duration: 0.3s, 
	$content-background: none, 
	$content-padding: 0rem, 
	$content-border-style: none, 
	$content-border-width: 1px, 
	$content-border-color: $color-primary, 
	$content-border-radius: 0px, 
	$box-shadow-secondary: none
) {
	//Responsive variables;
	$columns-lg: nth(inherit-list($columns),1);
	$columns-md: nth(inherit-list($columns),2);
	$columns-xs: nth(inherit-list($columns),3);

	//colors

	$trigger-background-check: first-color($trigger-background, $color-background);
	$trigger-background-check-active: first-color($trigger-background-active, $trigger-background-check);
	$trigger-color: preset-text-color($trigger-background-check);
	$trigger-color-active: preset-text-color($trigger-background-check-active);

	$items: 24;
	$content-background-check: first-color($content-background, $color-background);
	$text-color: preset-text-color($content-background-check);

	//Row Settings
	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive:true
	);

	// IE 11 image marign bug fix
	@media screen and (-ms-high-contrast:active),(-ms-high-contrast:none) and (min-width: $breakpoint-md) {
		> .inner { min-height: 1%; }
	}

	> .inner {
		body:not(.edit) & {
			@if $columns-xs > 1 {
				> figure.image-accordion-trigger {
					@for $i from 1 through $items {
						&:nth-of-type(#{$i}) {
							$row: floor(($i - 1) / $columns-xs);
						
							order: $row * 2 + 1;
						
							+ .image-accordion-content { order: $row * 2 + 2; }
						}
					}
				}
			}
		
			@media screen and (min-width: $breakpoint-xs) {
				> figure.image-accordion-trigger {
					@for $i from 1 through $items {
						&:nth-of-type(#{$i}) {
							$row: floor(($i - 1) / $columns-md);
						
							order: $row * 2 + 1;
						
							+ .image-accordion-content { order: $row * 2 + 2; }
						}
					}
				}
			}
			@media screen and (min-width: $breakpoint-md) {
				> figure.image-accordion-trigger {
					@for $i from 1 through $items {
						&:nth-of-type(#{$i}) {
							$row: floor(($i - 1) / $columns-lg);
						
							order: $row * 2 + 1;
						
							+ .image-accordion-content { order: $row * 2 + 2; }
						}
					}
				}
			}
		}
	}

	.image-accordion-trigger {
		//Column Settings
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		position: relative;
		//Border Radius
		@include media-constructor(border-radius, $trigger-border-radius);
	
		a {
			display: block;
			position: relative;
			overflow: hidden;
			//Border
			@include media-constructor(border-width, $trigger-border-width);
		
			border: {
				style: $trigger-border-style;
				color: $trigger-border-color;
			}
		
			//Border Radius
			@include media-constructor(border-radius, $trigger-border-radius);
		
			//Box Shadow
			@include media-constructor(box-shadow, $box-shadow-primary);
		
			> span {
				//Border Radius -- If you use Zoom-Trigger-Animation necessary
				@if $trigger-animation == "zoomIn" or $trigger-animation == "zoomOut" {
					@include media-constructor(border-radius, $trigger-border-radius);
				}
			
				@if $feature-transitions {
					transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
					transition-property: height, background-color;
				}
			}
		}
	
		img {
			//Border Radius -- If you use Shadow-Trigger-Animation necessary
			width: 100%;
			//Border Radius
			@include media-constructor(border-radius, $trigger-border-radius);
		}
	
		/* Default animation: bottom */
		a > span {
			position: absolute;
			bottom: 0;
		
			@include media-constructor(padding-left, $spacer);
			@include media-constructor(padding-right, $spacer);
			@include media-constructor(height, $caption-height);
		
			width: 100%;
			display: flex;
			flex-direction: column;
			justify-content: center;
			margin: 0;
			background: $trigger-background;
			color: $trigger-color;
			transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
			//Border Radius -- If you use Shadow-Trigger-Animation necessary
			@include media-constructor(border-radius, $trigger-border-radius);
		
			p { margin: 0; }
		}
	
		a.active {
			border-color: $trigger-border-color-active;
		
			@if type-of($trigger-background) == color {
				> span {
					height: 100%;
					background: $trigger-background-active;
					color: $trigger-color-active;
				}
			}
		}
	
		@media (hover: hover) and (pointer: fine) {
			a:hover {
				border-color: $trigger-border-color-active;
			
				@if type-of($trigger-background) == color {
					> span {
						height: 100%;
						background: $trigger-background-active;
						color: $trigger-color-active;
					}
				}
			}
		}
	
		/* Animations */
		@if $trigger-animation == "top" {
			a > span {
				top: 0;
				left: 0;
				bottom: auto;
			}
		}
		@if $trigger-animation == "right" {
			a {
				overflow: hidden;
			
				> span {
					height: 100%;
					right: -100%;
					top: 0;
					bottom: auto;
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> span { right: 0; }
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> span { right: 0; }
						}
					}
				}
			}
		}
		@if $trigger-animation == "left" {
			a {
				overflow: hidden;
			
				> span {
					height: 100%;
					left: -100%;
					top: 0;
					bottom: auto;
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> span { left: 0; }
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> span { left: 0; }
						}
					}
				}
			}
		}
		@if $trigger-animation == "zoomIn" {
			a {
				> span {
					left: 50%;
					top: 50%;
					bottom: auto;
					transform: translate(-50%, -50%);
					height: 0px;
					width: 0px;
					opacity: 0;
				
					& * {
						transform: scale(0);
						transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
					}
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> span {
							opacity: 1;
							height: 100%;
							width: 100%;
							background: $trigger-background-active;
							color: $trigger-color-active;
						
							& * { transform: scale(1); }
						}
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> span {
								opacity: 1;
								height: 100%;
								width: 100%;
								background: $trigger-background-active;
								color: $trigger-color-active;
							
								& * { transform: scale(1); }
							}
						}
					}
				}
			}
		}
		@if $trigger-animation == "zoomOut" {
			a {
				> span {
					left: 50%;
					top: 50%;
					bottom: auto;
					transform: translate(-50%, -50%);
					height: 100%;
					width: 100%;
					opacity: 1;
				
					& * {
						transform: scale(1);
						transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
					}
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> span {
							opacity: 0;
							height: 0px;
							width: 0;
							background: $trigger-background-active;
							color: $trigger-color-active;
						
							& * { transform: scale(0); }
						}
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> span {
								opacity: 0;
								height: 0px;
								width: 0;
								background: $trigger-background-active;
								color: $trigger-color-active;
							
								& * { transform: scale(0); }
							}
						}
					}
				}
			}
		}
		@if $trigger-animation == "background" {
			a > span {
				left: 50%;
				top: 50%;
				bottom: auto;
				transform: translate(-50%, -50%);
				height: 100%;
				width: 100%;
			}
		}
		@if $trigger-animation == "grayscale" {
			a {
				> span {
					left: 50%;
					top: 50%;
					bottom: auto;
					transform: translate(-50%, -50%);
					height: 100%;
					width: 100%;
				}
			
				> img {
					filter: grayscale(1);
					transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> img { filter: grayscale(0); }
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> img { filter: grayscale(0); }
						}
					}
				}
			}
		}
		@if $trigger-animation == "blur" {
			a {
				> span {
					left: 50%;
					top: 50%;
					bottom: auto;
					transform: translate(-50%, -50%);
					height: 100%;
					width: 100%;
				}
			
				> img {
					filter: blur(0px);
					transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> img { filter: blur(1px); }
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> img { filter: blur(1px); }
						}
					}
				}
			}
		}
		@if $trigger-animation == "shadow" {
			a {
				overflow: visible;
			
				> span {
					left: 50%;
					top: 50%;
					bottom: auto;
					transform: translate(-50%, -50%);
					height: 100%;
					width: 100%;
				}
			
				> img {
					filter: drop-shadow(  0px 0px 0px rgba(0,0,0,0.1));
					transition: all $trigger-animation-duration cubic-bezier(0.16, 0, 0.28, 0.99);
				}
			
				&.active {
					@if type-of($trigger-background) == color {
						> img { filter: drop-shadow(  0px 10px 5px rgba(0,0,0,0.5)); }
					}
				}
			
				@media (hover: hover) and (pointer: fine) {
					&:hover {
						@if type-of($trigger-background) == color {
							> img { filter: drop-shadow(  0px 10px 5px rgba(0,0,0,0.5)); }
						}
					}
				}
			}
		}
	}

	.image-accordion-content {
		@include media-constructor(margin, extend-constructor('calc(',$margin,' / 2)'));
	
		background: $content-background;
		//Border
		@include media-constructor(border-width, $content-border-width);
	
		border: {
			style: $content-border-style;
			color: $content-border-color;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $content-border-radius);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-secondary);
	
		> .inner {
			@include media-constructor(padding, $content-padding);
			@include preset-headline-color($content-background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	}

	// body edit styles	
	.image-accordion-trigger {
		@include info-box($content: "Trigger " counter(trigger));
	
		counter-increment: trigger;
	}

	@if $content-border-style != none {
		.edit &	.image-accordion-content {
			&:before {
				content: "Content " counter(content);
				position: absolute;
				max-width: 100%;
				z-index: 1;
				top: 0;
				left: -1px;
				display: block;
				background: #f58220;
				color: #fff;
				padding: 4px;
				font-size: 12px;
				line-height: 1;
				font-family: Helvetica, sans-serif;
				white-space: nowrap;
			}
		
			&:hover:before { display: none; }
		
			counter-increment: content;
			position: relative;
		}
	}
	@else  {
		.image-accordion-content {
			@include info-box($content: "Content " counter(content));
		
			&:hover:before { display: none; }
		
			counter-increment: content;
		}
	}

	.edit & .image-accordion-content[data-animation*="\"initial\":\"show\""] {
		&:after {
			position: absolute;
			z-index: 1;
			height: 20px;
			top: 0;
			left: 65px;
			font-family: "FontAwesome";
			content: "\f06e";
			display: block;
			background: #f58220;
			color: #fff;
			padding: 4px;
			font-size: 12px;
			line-height: 1;
		}
	
		&:hover:after { display: none; }
	}
}

