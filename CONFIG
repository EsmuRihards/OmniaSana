	$header-color: first-color($header-color, preset-accent-color($header-background-check));
	$stripes-color: first-color($stripes-color, preset-text-color($stripes-background-check));

	// remove padding left and right if element is inside another container (already set on parent)
	.ed-container &,
	.ed-reference-container &,
	.ed-collection-container &,
	.ed-collection-item & {
		>.inner {
			padding: 0;
			max-width: none;
		}
	}

	.table-text {
		@media screen and (max-width: $breakpoint-sm-max) {
			overflow-x: scroll;
		}
	}

	table {
		background: $background;
		color: $text-color;
	
		td,
		th {
			font-weight: unset;
		
			@include media-constructor(padding, $padding);
			@include media-constructor(line-height, $lh-all);
		}
	
		td {
			@include media-constructor(font-size, $font-size);
		}
	
		thead > tr > th {
			background: $header-background;
			color: $header-color;
			border-color: $border-color-primary;
		
			@include media-constructor(font-size, $header-font-size);
		}
	
		@if $cell-alignment == "align_left" {
			tr > td,
			tr > th { text-align: left; }
		}
		@if $cell-alignment == "align_center" {
			tr > td,
			tr > th { text-align: center; }
		}
		@if $cell-alignment == "align_right" {
			tr > td,
			tr > th { text-align: right; }
		}
		@if $first-column == "align_left" {
			tr > td:first-child,
			tr > th:first-child { text-align: left; }
		}
		@if $last-column == "align_right" {
			tr > td:last-child,
			tr > th:last-child { text-align: right; }
		}
	
		// Different border styles
		@if $style == "border_default" {
			thead tr th {
				@include media-constructor(border-width, $border-width-primary);
			
				border: {
					style: $border-style-primary;
					color: $border-color-primary;
				}
			
				border-top: 0;
				border-left: 0;
				border-right: 0;
			}
		
			tbody tr:not(:last-child) {
				@include media-constructor(border-width, $border-width-secondary);
			
				border: {
					style: $border-style-secondary;
					color: $border-color-secondary;
				}
			
				border-top: 0;
				border-left: 0;
				border-right: 0;
			}
		}
	
		@if $style == "border-cross" or $style == "border-full" {
			tr {
				&:first-child {
					th,
					td { border-top: none; }
				}
			
				&:last-child td { border-bottom: none; }
			}
		
			td,
			th {
				&:first-child { border-left: none; }
				&:last-child { border-right: none; }
			}
		
			td {
				@include media-constructor(border-width, $border-width-secondary);
			
				border: {
					style: $border-style-secondary;
					color: $border-color-secondary;
				}
			}
		
			th {
				@include media-constructor(border-width, $border-width-primary);
			
				border: {
					style: $border-style-primary;
					color: $border-color-primary;
				}
			}
		
			@if $style == "border-full" {
				@include media-constructor(border-width, $border-width-secondary);
			
				border: {
					style: $border-style-secondary;
					color: $border-color-secondary;
				}
			}
		}
	
		// STRIPES Styles 
		tr {
			@if $stripes-style == "table_row" {
				&:nth-child(even) {
					@if type-of($stripes-background) == color { background: $stripes-background; }
				
					color: $stripes-color;
				}
			}
			@if $stripes-style == "table_column" {
				td:nth-child(even) {
					@if type-of($stripes-background) == color { background: $stripes-background; }
				
					color: $stripes-color;
					background-clip: padding-box;
				}
			}
		}
	
		// Hover styles 
		@if $hover-style == "table_hover_row" {
			tr {
				transition: $transition-base;
			
				@if type-of($hover-background) == color {
					&:hover { background: $hover-background; }
				}
			}
		}
		@if $hover-style == "cell" {
			tr td {
				transition: $transition-base;
			
				@if type-of($hover-background) == color {
					&:hover { background: $hover-background; }
				}
			}
		}
	
		body:not(.edit) & {
			@if $hover-style == "zoom-row" {
				tr {
					transition: $transition-base;
					transform: scale(1);
				
					&:hover { transform: scale(1.04); }
				
					@if type-of($hover-background) == color {
						&:hover { background: $hover-background; }
					}
				}
			}
			@if $hover-style == "zoom-cell" {
				tr td {
					transition: $transition-base;
					transform: scale(1);
				
					&:hover { transform: scale(1.04); }
				
					@if type-of($hover-background) == color {
						&:hover { background: $hover-background; }
					}
				}
			}
		}
	}
}

/**
* Columns - Three V2
* Last Update: 2025-02-11T12:10:37+01:00
* 
* @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
* @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
* @Param("margin", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
* @Param("margin-horizontal", type="bool", group="layout")
* @Param("box-background", type="color-type-selector", group="box")
* @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="box")
* @Param("box-border-style", type="choice", options={"choices"={"none","solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
* @Param("box-border-width", type="spacing", options={"units"={"px", "rem", "vw", "vh"}, "responsive"=1}, visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
* @Param("box-border-color", type="color", visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
* @Param("box-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box")
*/
@mixin columns-three-v2(
	$columns: 3 null 1, 
	$grow: false, 
	$margin: 2rem, 
	$margin-horizontal: false, 
	$box-background: none, 
	$box-padding: 0rem, 
	$box-border-style: none, 
	$box-border-width: 1px, 
	$box-border-color: $color-secondary, 
	$box-border-radius: 0, 
	$box-shadow-primary: none
) {
	$background-check: first-color($box-background,$color-background);
	$text-color: preset-text-color($background-check);

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive:true
	);

	> .inner > .columns-box {
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		> a,
		> a:hover {
			text-decoration: none;
			color: unset;
		}
	
		// Background
		@if $box-background != none {
			background: $box-background;
		
			@include preset-headline-color($background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $box-border-width);
	
		border: {
			style: $box-border-style;
			color: $box-border-color;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $box-border-radius);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		> .inner {
			@include media-constructor(padding, $box-padding);
		}
	}
}

