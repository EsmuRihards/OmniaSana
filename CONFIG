* @Param("trigger-border-color", type="color", visibility={"trigger-border-style"={"solid", "dashed", "dotted", "double"}}, options={"width"=50}, group="accordion_trigger")
* @Param("trigger-border-color-active", type="color", visibility={"trigger-border-style"={"solid", "dashed", "dotted", "double"}}, options={"width"=50}, group="accordion_trigger") 
* @Param("trigger-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="accordion_trigger")
* @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="accordion_trigger") 
* @Param("content-background", type="color-type-selector", group="content")
* @Param("content-padding", type="spacing", options={"units"={"none", "px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("content-border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="content")
* @Param("content-border-width", type="spacing", visibility={"content-border-style"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("content-border-color", type="color", visibility={"content-border-style"={"solid", "dashed", "dotted", "double"}}, group="content")
* @Param("content-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
* @Param("box-shadow-secondary", type="shadow", options={"responsive"=1}, group="content") 
*/
@mixin accordion-v3(
	$variant: row_icon, 
	$margin: 1rem, 
	$column-width: 25% 33% 100%, 
	$tab-grow: true, 
	$trigger-background: $color-primary, 
	$trigger-background-active: $color-secondary, 
	$trigger-color: none, 
	$trigger-color-active: none, 
	$font: none, 
	$trigger-font-size: $fz-base-all, 
	$trigger-icon: cross, 
	$trigger-icon-color: none, 
	$trigger-icon-color-active: none, 
	$trigger-margin: 1rem, 
	$trigger-padding: (1rem 1rem 1rem, null, null), 
	$trigger-border-style: none, 
	$trigger-border-width: 1px, 
	$trigger-border-color: $color-primary, 
	$trigger-border-color-active: $color-primary, 
	$trigger-border-radius: 0px, 
	$box-shadow-primary: none, 
	$content-background: $color-background, 
	$content-padding: 0rem, 
	$content-border-style: none, 
	$content-border-width: 1px, 
	$content-border-color: $color-primary, 
	$content-border-radius: 0px, 
	$box-shadow-secondary: none
) {
	//Responsive variables
	$column-width-lg: nth(inherit-list($column-width),1);
	$column-width-md: nth(inherit-list($column-width),2);
	$column-width-xs: nth(inherit-list($column-width),3);

	$tab-grow-lg: nth(inherit-list($tab-grow),1);
	$tab-grow-md: nth(inherit-list($tab-grow),2);
	$tab-grow-xs: nth(inherit-list($tab-grow),3);

	$trigger-margin-lg: nth(inherit-list($trigger-margin),1);
	$trigger-margin-md: nth(inherit-list($trigger-margin),2);
	$trigger-margin-xs: nth(inherit-list($trigger-margin),3);

	@if length($trigger-padding) == 1 {
		$trigger-padding: ($trigger-padding $trigger-padding $trigger-padding $trigger-padding, null, null);
	}

	$trigger-padding-right-lg: nth(nth(inherit-list($trigger-padding),1),2);
	$trigger-padding-right-md: nth(nth(inherit-list($trigger-padding),2),2);
	$trigger-padding-right-xs: nth(nth(inherit-list($trigger-padding),3),2);

	//Colors            
	$trigger-background-check: first-color($trigger-background,$color-background);
	$trigger-background-check-active: first-color($trigger-background-active, $trigger-background-check);

	$content-background-check: first-color($content-background, $color-background);

	$headline-color: preset-accent-color($trigger-background-check);
	$headline-color-active: preset-accent-color($trigger-background-check-active);

	$text-color: preset-text-color($content-background-check);

	$trigger-color: if(type-of($trigger-color) == color,$trigger-color,$headline-color);
	$trigger-color-active: if(type-of($trigger-color-active) == color,$trigger-color-active,$headline-color-active);
	$trigger-icon-color: if(type-of($trigger-icon-color) == color,$trigger-icon-color,$headline-color);
	$trigger-icon-color-active: if(type-of($trigger-icon-color-active) == color,$trigger-icon-color-active,$headline-color-active);

	$svg-color: str-slice(inspect($trigger-icon-color), 2);
	$svg-color-active: str-slice(inspect($trigger-icon-color-active), 2);

	// remove padding left and right if element is inside another container (already set on parent)
	.ed-container &,
	.ed-reference-container &,
	.ed-collection-container &,
	.ed-collection-item & {
		>.inner {
			padding: 0;
			max-width: none;
		}
	}

	// - accordion margin fix 
	> .inner > .ed-element {
		@if $variant != "list_icon" {
			&:first-child {
				@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin,' /2)'));
			}
			&:last-child {
				@include media-constructor(margin-bottom, extend-constructor('calc(',$trigger-margin,' /2)'));
			}
		
			@include media-constructor(margin-left, extend-constructor('calc(',$trigger-margin,' /2)'));
			@include media-constructor(margin-right, extend-constructor('calc(',$trigger-margin,' /2)'));
			@include media-constructor(width, extend-constructor('calc(100% - ', $trigger-margin ,')'));
			@include media-constructor(max-width, extend-constructor('calc(100% - ', $trigger-margin ,')'));
		}
	}

	//grid is getting destroyed is grid-row works 
	@if $variant != "list_icon" {
		//Row Settings
		@include flex-grid-row($margin: $trigger-margin, $responsive: true);
	}

	> .inner > .accordion-trigger a {
		display: block;
	
		@include media-constructor(padding, $trigger-padding);
	
		position: relative;
		text-decoration: none;
		color: $trigger-color;
		background: $trigger-background;
	
		@if $font != none and $font != "" { font-family: $font; }
	
		@include media-constructor(font-size, $trigger-font-size);
	
		//Border
		@include media-constructor(border-width, $trigger-border-width);
	
		//Border Radius
		@include media-constructor(border-radius, $trigger-border-radius);
	
		border: {
			style: $trigger-border-style;
			color: $trigger-border-color;
		}
	
		@if $trigger-icon != "none" {
			@include media-constructor(padding-right, extend-constructor('calc(', $trigger-font-size ,' + 2rem)'));
		}
	
		@else  {
			@include media-constructor(padding-right, $trigger-font-size);
		
			&:after { background: none; }
		}
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		transition: $transition-base;
		transition-property: color, background;
	
		&.active {
			color: $trigger-color-active;
			background: $trigger-background-active;
			border-color: $trigger-border-color-active;
		}
	
		@media (hover: hover) and (pointer: fine) {
			&:hover {
				color: $trigger-color-active;
				background: $trigger-background-active;
				border-color: $trigger-border-color-active;
			}
		}
	
		@if $trigger-icon == "chevron" or $trigger-icon == "cross" {
			&:after {
				display: block;
				position: absolute;
				right: $trigger-padding-right-lg;
			
				@media screen and (max-width: $breakpoint-md-max) {
					right: $trigger-padding-right-md;
				}
				@media screen and (max-width: $breakpoint-sm-max) {
					right: $trigger-padding-right-xs;
				}
			
				top: 50%;
				transform: translateY(-50%);
				content: "";
			
				@include media-constructor(height, $trigger-font-size);
				@include media-constructor(width, $trigger-font-size);
			
				transition: $transition-base;
			}
		}
	
		@if $trigger-icon == "chevron" {
			&:after {
				// set color in background and cut # from it because # isnt allowed in urls - using %23 as a replacement
				background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color}" viewBox="0 -320 448 256" data-icon="ion-ion-chevron-up" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M224 -234l-174 167c-4 4 -12 4 -16 -0l-31 -30c-4 -4 -4 -12 0 -16l213 -204c2 -2 5 -3 8 -3s6 1 8 3l213 204c4 4 4 12 0 16l-31 30c-4 4 -12 4 -16 -0l-174 -167v-0v-0z"></path></svg>') no-repeat center;
				transform: translateY(-50%) rotate(180deg);
			}
		
			&.active:after {
				transform: translateY(-50%) rotate(0deg);
				background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color-active}" viewBox="0 -320 448 256" data-icon="ion-ion-chevron-up" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M224 -234l-174 167c-4 4 -12 4 -16 -0l-31 -30c-4 -4 -4 -12 0 -16l213 -204c2 -2 5 -3 8 -3s6 1 8 3l213 204c4 4 4 12 0 16l-31 30c-4 4 -12 4 -16 -0l-174 -167v-0v-0z"></path></svg>') no-repeat center;
			}
		
			@media (hover: hover) and (pointer: fine) {
				&:hover:after { background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color-active}" viewBox="0 -320 448 256" data-icon="ion-ion-chevron-up" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M224 -234l-174 167c-4 4 -12 4 -16 -0l-31 -30c-4 -4 -4 -12 0 -16l213 -204c2 -2 5 -3 8 -3s6 1 8 3l213 204c4 4 4 12 0 16l-31 30c-4 4 -12 4 -16 -0l-174 -167v-0v-0z"></path></svg>') no-repeat center; }
			}
		}
	
		@if $trigger-icon == "cross" {
			&:after {
				// set color in background and cut # from it because # isnt allowed in urls - using %23 as a replacement
				background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color}" viewBox="0 -320 256 256" data-icon="ion-ion-ios-plus-empty" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M256 -183h-120v119h-17v-119h-119v-17h119v-120h17v120h120v17z"></path></svg>') no-repeat center;
			}
		
			&.active:after {
				transform: translateY(-50%) rotate(45deg);
				background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color-active}" viewBox="0 -320 256 256" data-icon="ion-ion-ios-plus-empty" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M256 -183h-120v119h-17v-119h-119v-17h119v-120h17v120h120v17z"></path></svg>') no-repeat center;
			}
		
			@media (hover: hover) and (pointer: fine) {
				&:hover:after { background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" fill="%23#{$svg-color-active}" viewBox="0 -320 256 256" data-icon="ion-ion-ios-plus-empty" preserveAspectRatio="xMidYMid" id="" class=" "><path d="M256 -183h-120v119h-17v-119h-119v-17h119v-120h17v120h120v17z"></path></svg>') no-repeat center; }
			}
		}
	}

	> .inner > .accordion-content {
		background: $content-background;
		//Border
		@include media-constructor(border-width, $content-border-width);
	
		//Border Radius
		@include media-constructor(border-radius, $content-border-radius);
	
		border: {
			style: $content-border-style;
			color: $content-border-color;
		}
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-secondary);
	
		> .inner {
			@include preset-headline-color($content-background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		
			@include media-constructor(padding, $content-padding);
		
			p:last-child { margin: 0; }
		}
	}

	/*VARIANTS*/
	// row_icon
	@if $variant == "row_icon" {
		//Set margin between trigger
		> .inner > .accordion-trigger:not(:nth-last-child(2)) {
			@include media-constructor(margin-bottom, $trigger-margin);
		}
	
		//need to set a margin bottom for right inner calc
		> .inner > .accordion-trigger:nth-last-child(2) {
			@include media-constructor(margin-bottom, extend-constructor('calc(',$trigger-margin,' /2)'));
		}
	
		> .inner > .accordion-content {
			@include media-constructor(margin-bottom, $margin);
		
			&:not(:nth-last-child(2)) {
				@include media-constructor(margin-top, extend-constructor('calc(', $margin, ' -'), extend-constructor('', $trigger-margin, ')'));
			}
			&:last-child {
				@include media-constructor(margin-top, extend-constructor('calc(', $margin, ' -'), extend-constructor('', $trigger-margin, ' /2)'));
			}
		}
	}

	@if $variant == "list_icon" {
		> .inner > .accordion-trigger:not(:first-of-type) {
			@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin,')'));
		}
	
		@supports (display: grid) {
			> .inner {
				display: grid;
			
				@include media-constructor(grid-column-gap, extend-constructor('calc(',$margin,')'));
			
				.edit & > .ed-element.accordion-content {
					&:not(:nth-child(2)) {
						@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin,')'));
					}
				
					@include media-constructor(margin-bottom, extend-constructor('calc(',$trigger-margin,')'));
				}
			}
		
			.accordion-trigger { grid-column-start: 1; }
		
			body:not(.edit) & .accordion-content {
				grid-row: 1/24;
				grid-column: 2 / 2;
			}
		
			@if nth($column-width-lg,1) >= 100% {
				> .inner {
					grid-template-columns: 100%;
				
					> .ed-element.accordion-content {
						@include media-constructor(margin-top, extend-constructor('calc(',$margin,')'));
					}
				}
			
				body:not(.edit) & .accordion-content {
					grid-row: auto;
					grid-column: auto;
				}
			}
		
			@else  {
				// grid-template-columns: 50% 1fr; gets different values, need to translate it into fr 
				$first-width: strip-units($column-width-lg)+fr;
				$second-width: 100 - strip-units($column-width-lg)+fr;
			
				> .inner { grid-template-columns: $first-width $second-width; }
			}
		
			@media screen and (max-width: $breakpoint-md-max) {
				@if nth($column-width-md,1) >= 100% {
					> .inner {
						grid-template-columns: 100%;
					
						> .ed-element.accordion-content {
							@include media-constructor(margin-top, extend-constructor('calc(',$margin,')'));
						}
					}
				
					body:not(.edit) & .accordion-content {
						grid-row: auto;
						grid-column: auto;
					}
				}
			
				@else  {
					> .inner { grid-template-columns: $column-width-md 1fr; }
				}
			}
		
			@media screen and (max-width: $breakpoint-sm-max) {
				@if nth($column-width-xs,1) >= 100% {
					> .inner {
						grid-template-columns: 100%;
					
						> .ed-element.accordion-content {
							@include media-constructor(margin-top, extend-constructor('calc(',$margin,')'));
						}
					}
				
					body:not(.edit) & .accordion-content {
						grid-row: auto;
						grid-column: auto;
					}
				}
			
				@else  {
					> .inner { grid-template-columns: $column-width-xs 1fr; }
				}
			}
		}
	}

	@if $variant == "tabs_icon" {
		> .inner {
			display: flex;
		
			> .ed-element {
				flex-grow: if($tab-grow-lg,1,0);
			
				@media screen and (max-width: $breakpoint-md-max) {
					flex-grow: if($tab-grow-md,1,0);
				}
				@media screen and (max-width: $breakpoint-sm-max) {
					flex-grow: if($tab-grow-xs,1,0);
				}
			}
		
			> .ed-element {
				@include media-constructor(max-width, extend-constructor('calc(100% - (', $trigger-margin-lg ,' *2) /2)'));
			
				width: auto;
			
				&.accordion-trigger {
					@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin-lg,' /2)'));
				}
				&.accordion-content {
					@include media-constructor(margin-top, $margin);
				}
			
				@media screen and (max-width: $breakpoint-md-max) {
					@include media-constructor(max-width, extend-constructor('calc(100% - (', $trigger-margin-md ,' *2) /2)'));
				
					&.accordion-trigger {
						@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin-md,' /2)'));
					}
				}
			
				@media screen and (max-width: $breakpoint-sm-max) {
					@include media-constructor(width, extend-constructor('calc(100% - (', $trigger-margin-xs ,' *2) /2)'));
					@include media-constructor(max-width, extend-constructor('calc(100% - (', $trigger-margin-xs ,' *2) /2)'));
				
					&.accordion-trigger {
						@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin-xs,' /2)'));
					}
				}
			}
		
			@media screen and (min-width: $breakpoint-sm-max) {
				> .ed-headline {
					order: -1;
					flex-basis: auto;
				}
			}
		}
	
		@media screen and (max-width: $breakpoint-sm-max) {
			> .inner > .accordion-trigger:not(:first-of-type) {
				@include media-constructor(margin-top, extend-constructor('calc(',$trigger-margin-xs,' /2)'));
			}
			> .inner > .ed-element:nth-last-child(2) a:not(.active) {
				@include media-constructor(margin-bottom, extend-constructor('calc(',$trigger-margin-xs,' /2)'));
			}
		}
	}

	// body edit styles	
	.accordion-trigger {
		@include info-box($content: "Trigger " counter(trigger));
	
		counter-increment: trigger;
	}

	@if $content-border-style != none {
		.edit &	.accordion-content {
			&:before {
				content: "Content " counter(content);
				position: absolute;
				max-width: 100%;
				z-index: 1;
				top: 0;
				left: -1px;
				display: block;
				background: #f58220;
				color: #fff;
				padding: 4px;
				font-size: 12px;
				line-height: 1;
				font-family: Helvetica, sans-serif;
				white-space: nowrap;
			}
		
			&:hover:before { display: none; }
		
			counter-increment: content;
			position: relative;
		}
	}
	@else  {
		.accordion-content {
			@include info-box($content: "Content " counter(content));
		
			&:hover:before { display: none; }
		
			counter-increment: content;
		}
	}

	.edit & .accordion-content[data-animation*="\"initial\":\"show\""] {
		&:after {
			position: absolute;
			z-index: 1;
			top: 0;
			left: 65px;
			content: "\f06e";
			display: block;
			background: #f58220;
			color: #fff;
			padding: 4px;
			font-size: 12px;
			line-height: 1;
			font-family: "FontAwesome";
			opacity: 0.75;
		}
	
		&:hover:after { display: none; }
	}
}

/**
 * @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")
 * @Param("box-background", type="color-type-selector", group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none","solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", options={"units"={"px", "rem", "vw", "vh"}, "responsive"=1}, visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
 * @Param("hover-effect", type="bool", group="box")
 * @Param("icon-background", type="color-type-selector", options={"width"=60}, group="icon")
 * @Param("icon-color", type="color", options={"width"=40}, group="icon")
 * @Param("fz-icon", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("icon-padding", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("border-style-secondary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="icon")
 * @Param("border-width-secondary", type="spacing",visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("border-color-secondary",visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, type="color", group="icon")
 * @Param("border-radius-secondary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("box-shadow-secondary", type="shadow", options={"responsive"=1}, group="icon") 
 * @Param("text-color", type="color", group="headline")
 * @Param("text-font", type="choice", options={"choices"={"default-font", "special-font"}, "expanded"=1}, group="headline")
 * @Param("text-fz-headline", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="headline")
 * @Param("padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="headline")
 */
@mixin icon-list-v3(
	$columns: 2 null 1, 
	$grow: false, 
	$margin: (1rem, null, 0.5rem), 
	$margin-horizontal: false, 
	$box-background: $color-background, 
	$border-style-primary: solid, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-primary, 
	$border-radius-primary: 0px, 
	$box-shadow-primary: none, 
	$hover-effect: false, 
	$icon-background: $color-primary, 
	$icon-color: none, 
	$fz-icon: ( 1rem , null , null), 
	$icon-padding: 1rem, 
	$border-style-secondary: none, 
	$border-width-secondary: 1px, 
	$border-color-secondary: $color-primary, 
	$border-radius-secondary: 0, 
	$box-shadow-secondary: none, 
	$text-color: none, 
	$text-font: default-font, 
	$text-fz-headline: (1rem, null , null), 
	$padding: (1rem, null, null)
) {
	//Colors                   
	$background-check: first-color($box-background, $color-background);

	$icon-background-check: first-color($icon-background,$background-check);
	$icon-color: if(type-of($icon-color) == color,$icon-color,preset-accent-color($icon-background-check));

	$text-color: first-color($text-color, preset-accent-color($background-check));

	@if $hover-effect { overflow: visible; }

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive: true
	);

	.icon-list-box {
		//Column Settings
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		position: relative;
		background: $box-background;
	
		@include media-constructor(margin, extend-constructor('calc(',$margin,' /2)'));
		@include media-constructor(font-size, $text-fz-headline);
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		.ed-headline {
			display: flex;
			align-items: center;
			word-break: break-word;
			//Break fix
			@include media-constructor(max-width, extend-constructor('calc(100% - ', $icon-padding, ' *2'),  extend-constructor(' - ', $border-width-secondary, ' *2'), extend-constructor(' - ', $fz-icon, ')'));
			@include media-constructor(padding, $padding);
		}
	
		h1,
		h2,
		h3,
		h4,
		h5,
		h6 {
			@include media-constructor(font-size, $text-fz-headline);
		
			max-width: 100%;
			color: $text-color;
		
			@if $text-font == "default-font" { font-family: $font-default; }
			@else  { font-family: $ff-headlines; }
		}
	
		.icon-list-icon {
			display: flex;
			align-items: center;
			align-content: center;
			justify-content: center;
		
			@include media-constructor(padding, $icon-padding);
		
			svg {
				display: block;
				fill: $icon-color;
			
				@include media-constructor(width, $fz-icon);
				@include media-constructor(height, $fz-icon);
				@include media-constructor(line-height, $fz-icon);
			}
		
			@if type-of($icon-background) == "color" {
				background: $icon-background;
				text-align: center;
			}
		
			@else if type-of($icon-background) != "color" and $icon-background != none {
				background: $icon-background;
				text-align: center;
			}
		
			//Border
			@include media-constructor(border-width, $border-width-secondary);
		
			border: {
				style: $border-style-secondary;
				color: $border-color-secondary;
			}
		
			//Border Radius
			@include media-constructor(border-radius, $border-radius-secondary);
		
			//Box Shadow
			@include media-constructor(box-shadow, $box-shadow-secondary);
		}
	
		@if $hover-effect and $feature-animations {
			transition: $transition-base;
			transition-property: transform;
		
			&:hover { transform: scale(1.03); }
		}
	}
}

/**
 * @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")
 * @Param("box-featured", type="bool", options={"width"=60}, group="layout")
 * @Param("box-highlight-factor", type="number", visibility={"box-featured" : true}, options={"units"={"%"}, "width"=40, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("box-background", type="color", group="box")
 * @Param("highlight-fz", type="number", options={"units"={"rem", "px", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-padding", type="number", options={"units"={"rem", "px", "%", "vw", "vh"}, "responsive"=1}, group="box")
 * @Param("box-border-style", type="choice", options={"choices"={"none","solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("box-border-width", type="spacing", options={"units"={"px", "rem", "vw", "vh"}, "responsive"=1}, visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("box-border-color", type="color", visibility={"box-border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("box-border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
 * @Param("head-background", type="color", group="head")
 * @Param("head-fz", type="number", options={"units"={ "px","rem", "%", "vh", "vw"}, "responsive"=1}, group="head")
 * @Param("head-icon-fz", type="number", options={"units"={ "px","rem", "vh", "vw"}, "responsive"=1}, group="head")
 * @Param("hover-scale", type="bool", desc="scale hover effect 1.05 for the box", group="effects")
 */
@mixin pricing-boxes-v3(
	$columns: 3 null 1, 
	$grow: false, 
	$margin: 1rem, 
	$margin-horizontal: false, 
	$box-featured: true, 
	$box-highlight-factor: 100% null null, 
	$box-background: $color-background, 
	$highlight-fz: 2rem, 
	$box-padding: 1rem, 
	$box-border-style: none, 
	$box-border-width: 1px, 
	$box-border-color: none, 
	$box-border-radius: 0, 
	$box-shadow-primary: none, 
	$head-background: $color-primary, 
	$head-fz: $fz-base-all, 
	$head-icon-fz: 2rem, 
	$hover-scale: false
) {
	$box-padding: inherit-list($box-padding);
	$box-highlight-factor: inherit-list($box-highlight-factor);
	$box-highlight-padding: (
			    nth($box-padding, 1) * (1 + strip-units(nth($box-highlight-factor, 1))/100)
			    nth($box-padding, 2) * (1 + strip-units(nth($box-highlight-factor, 2))/100)
			    nth($box-padding, 3) * (1 + strip-units(nth($box-highlight-factor, 3))/100)
			);

	// Colors

	$background-check: first-color($box-background,$color-background);
	$head-background-check: first-color($head-background,$box-background,$color-background);
	$text-color: preset-text-color($background-check);
	$head-text-color: preset-text-color($head-background-check);

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive: true
	);

	.pricing-boxes-box {
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$ie: true
		);
	
		@if type-of($box-background) == color and $box-background != none {
			background: $box-background;
		
			&,
			.ed-text a,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		@include media-constructor(border-width, $box-border-width);
		@include media-constructor(border-radius, $box-border-radius);
	
		border: {
			style: $box-border-style;
			color: $box-border-color;
		}
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		p,
		ul {
			margin: 0;
			padding: 0;
		
			li {
				padding: $padding-vertical;
			
				&:not(:last-child) { border-bottom: 1px solid rgba(#000,.05); }
				&:before { display: none; }
			}
		}
	}

	.pricing-boxes-head,
	.pricing-boxes-content {
		> .inner {
			@include media-constructor(padding, $box-padding);
		}
	}

	.pricing-boxes-head {
		background: $head-background;
		color: $head-text-color;
		text-transform: uppercase;
		font-weight: bold;
	
		svg {
			display: block;
			fill: $head-text-color;
		
			@include media-constructor(height, $head-icon-fz);
			@include media-constructor(width, $head-icon-fz);
			@include media-constructor(line-height, $head-icon-fz);
			@include media-constructor(margin-bottom, $padding-vertical);
		}
	
		.ed-text {
			@include media-constructor(font-size, $head-fz);
		}
	}

	.pricing-boxes-highlight {
		@include media-constructor(font-size, $highlight-fz);
	}

	@if $box-featured {
		> .inner {
			align-content: center;
			align-items: center;
		}
	
		.pricing-boxes-featured {
			@include media-constructor(margin-top, extend-constructor('calc(',$margin,' /2)'));
			@include media-constructor(margin-bottom, extend-constructor('calc(',$margin,' /2)'));
		
			z-index: 1;
		
			.pricing-boxes-head > .inner,
			.pricing-boxes-content > .inner {
				@include media-constructor(padding, $box-highlight-padding);
			}
		}
	}

	// if animations and hover-style effect are enabled, scale on hover
	@if $hover-scale == true {
		overflow: visible;
	
		.pricing-boxes-box {
			transition: $transition-base;
			transition-property: transform;
		
			&:hover { transform: scale(1.025); }
		}
	}
}

/**
 Footer Saga
 * Last Update: 2025-02-11T11:49:19+01:00
 *
 * @Param("background", type="color-type-selector", group="layout")
 * @Param("columns", type="choice", group="columns", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"rem", "px", "%", "vh", "vw"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")
 * @Param("box-background", type="color-type-selector", group="box")
 * @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted","double"}, "expanded"=1}, group="box")
 * @Param("border-width", type="spacing",visibility={"border-style"={ "solid", "dashed", "dotted","double"}},  options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-color", type="color", visibility={"border-style"={ "solid", "dashed", "dotted","double"}}, group="box")
 * @Param("border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box")
 * @Param("icon-color", type="color", group="icon")
 * @Param("icon-size", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("icon-margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 */
@mixin footer-saga-v3(
	$background: $color-primary, 
	$columns: 4 2 1, 
	$grow: false, 
	$margin: 1rem, 
	$margin-horizontal: false, 
	$box-background: none, 
	$box-padding: 0rem, 
	$border-style: none, 
	$border-width: 1px, 
	$border-color: $color-primary, 
	$border-radius: 0px, 
	$box-shadow-primary: none, 
	$icon-color: none, 
	$icon-size: 1rem, 
	$icon-margin: 0.6rem
) {
	$background-check: first-color($box-background, $background, $color-background);
	$text-color: preset-text-color($background-check);
	$icon-color: first-color($icon-color, preset-text-color($background-check));
	$border-color: first-color($border-color,prioritize-color($background: $background-check));

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive: true
	);

	background: $background;

	&,
	a,
	a:hover { color: $text-color; }

	.footer-saga-box {
		background: $box-background;
		max-width: 100%;
		// Determine proper background color for logo
		@if $logo-background != false and $logo-transparent == false and abs(brightness($color-primary) - brightness($logo-background))>20% { background: $logo-background; }
		@else if $logo-luminance > 0.75 and $logo-transparent { background: color-contrast($white, $color-default, $color-secondary); }
	
		//Border
		@include media-constructor(border-width, $border-width);
	
		border: {
			style: $border-style;
			color: $border-color;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius);
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		> .inner {
			@include media-constructor(padding, $box-padding);
		}
	
		@include preset-headline-color($background-check);
	
		.ed-text ul,
		.ed-menu ul {
			margin: 0;
			padding: 0;
		
			li {
				list-style: none;
				margin: 0;
				padding: 0;
			
				&:before { display: none; }
			}
		}
	
		.ed-text {
			@include media-constructor(flex-basis, extend-constructor('calc(100% - ', $icon-size, ''), extend-constructor(' - ', $icon-margin, ')'));
		
			flex-grow: 1;
		}
	
		// :not necessary if you want to combine social icon preset and footer, otherwise the social icons will also be manipulated
		.ed-icon:not(.social-icons-icon) {
			flex: 1 1 auto;
		
			i,
			svg:not(.social-icons-icon) {
				fill: $icon-color;
				color: $icon-color;
				vertical-align: baseline;
			
				@include media-constructor(margin-right, $icon-margin);
				@include media-constructor(max-height, $icon-size);
				@include media-constructor(width, $icon-size);
			}
		}
	}
}

/**
* Footer "Bragi"
* Last Update: 2025-02-11T11:47:35+01:00
*
* @Param("width", type="number", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
* @Param("separator-variant", type="choice", options={"choices"={"none", "triangle_icon", "triangle-invert_icon", "diagonal_icon", "diagonal-invert_icon"}, "responsive"=1, "expanded"=1}, group="layout")
* @Param("separator-width", type="number", visibility={"separator-variant"={"triangle_icon", "triangle-invert_icon", "diagonal_icon", "diagonal-invert_icon"}}, options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
* @Param("background", type="color-type-selector", group="layout")
* @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vw", "vh"}, "responsive"=1}, group="layout")
* @Param("icon-color", type="color", group="icon")
* @Param("icon-size", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
* @Param("icon-margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
*/
@mixin footer-bragi-v3(
	$background: $color-secondary, 
	$width: 50% null 100%, 
	$box-padding:(0 1rem 0 0rem, 0 1rem, null), 
	$separator-variant: none, 
	$separator-width: 3rem, 
	$icon-color: none, 
	$icon-size: 1rem, 
	$icon-margin: 0.6rem
) {
	$background-check: first-color($background, $color-background);
	$text-color: preset-text-color($background-check);

	$icon-background-check: first-color($background, $color-background);
	$icon-color: first-color($icon-color, preset-accent-color($icon-background-check));

	$separator-variant-lg: nth(inherit-list($separator-variant),1);
	$separator-variant-md: nth(inherit-list($separator-variant),2);
	$separator-variant-xs: nth(inherit-list($separator-variant),3);

	$width-lg: nth(inherit-list($width),1);
	$width-md: nth(inherit-list($width),2);
	$width-xs: nth(inherit-list($width),3);

	//calculation for inner container left

	$content-width-rem: to-rem($content-width);
	$margin-calculation: calc(50vw - #{$content-width-rem} / 2 + #{$spacer});

	background: $background;

	&,
	a,
	a:hover { color: $text-color; }

	.footer-bragi-box {
		@include preset-headline-color($background-check);
		@include media-constructor(padding, $box-padding);
	
		//calculation for inner width
		@if nth($width-lg, 1) == 100% or nth($width-lg,1) == 100vw {
			flex-basis: 100% !important;
			margin: 0;
		}
	
		@else  {
			@include media-constructor(flex-basis, extend-constructor('calc(', $width-lg , ' '), extend-constructor('- ', $margin-calculation, ') !important'));
		
			&:first-child {
				margin-left: $margin-calculation;
				margin-right: 0;
			
				@if $content-width-rem > $breakpoint-md {
					@media screen and (max-width: $content-width-rem) and (min-width: $breakpoint-md) {
						margin-left: 0;
						padding-left: 1rem;
					}
				}
			}
		
			margin-right: $margin-calculation;
			margin-left: 0;
		}
	
		@media screen and(max-width: $breakpoint-md-max) {
			@if nth($width-md, 1) == 100% or nth($width-md,1) == 100vw {
				flex-basis: 100% !important;
				margin: 0 !important;
			}
		
			@else  {
				@include media-constructor(flex-basis, extend-constructor('calc(', $width-md , ') !important'));
			
				&:first-child { margin-left: 0; }
			
				margin-right: 0;
			}
		}
	
		@media screen and(max-width: $breakpoint-xs-max) {
			@if nth($width-xs, 1) == 100% or nth($width-xs,1) == 100vw {
				flex-basis: 100% !important;
				margin: 0 !important;
			}
		
			@else  {
				@include media-constructor(flex-basis, extend-constructor('calc(', $width-xs , ') !important'));
			
				&:first-child { margin-left: 0; }
			
				margin-right: 0;
			}
		}
	}

	p {
		&:last-child { margin-bottom: 0; }
	}

	.ed-text {
		@include media-constructor(flex-basis, extend-constructor('calc(100% - ', $icon-size, ''), extend-constructor(' - ', $icon-margin, ')'));
	
		flex-grow: 1;
	}

	// :not necessary if you want to combine social icon preset and footer, otherwise the social icons will also be manipulated
	.ed-icon:not(.social-icons-icon) {
		flex: 1 1 auto;
	
		i,
		svg:not(.social-icons-icon) {
			fill: $icon-color !important;
			color: $icon-color;
			vertical-align: baseline;
		
			@include media-constructor(margin-right, $icon-margin);
			@include media-constructor(max-height, $icon-size);
			@include media-constructor(width, $icon-size);
		}
	}

	.footer-bragi-map > .inner { pointer-events: none; }

	.footer-bragi-map {
		//separator Setup
		&:before {
			content: "";
			position: absolute;
			background: $background;
			z-index: 1;
			pointer-events: none;
		}
	
		// separator type and position
		@if nth($width-lg,1) == 100% or nth($width-lg,1) == 100vw {
			&:before {
				width: 100%;
				left: 0px;
				top: -1px;
				display: flex;
			
				@include media-constructor(height, $separator-width);
			}
		
			&:first-child::before {
				bottom: -1px;
				top: auto;
				right: 0px;
				transform: rotate(180deg);
			}
		
			// Elements if width == 100%
			@if nth($separator-variant-lg, 1) == "none" {
				&:before { display: none; }
			}
		
			// Triangle
			@else if nth($separator-variant-lg, 1) == "triangle_icon" {
				&:before { clip-path: polygon(100% 0, 0 0, 50% 100%); }
			}
		
			// Triangle invert
			@else if nth($separator-variant-lg, 1) == "triangle-invert_icon" {
				&:before { clip-path: polygon(100% 100%, 50% 0, 0% 100%, 0 0, 100% 0); }
			}
		
			// Diagonal
			@else if nth($separator-variant-lg,1) == "diagonal_icon" {
				&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
			}
		
			// Diagonal invert
			@else if nth($separator-variant-lg,1) == "diagonal-invert_icon" {
				&:before { clip-path: polygon(100% 0, 0 0, 100% 100%); }
			}
		}
	
		@else  {
			&:before {
				left: -1px;
				top: 0;
				height: 100%;
				display: flex;
			
				@include media-constructor(width, $separator-width);
			}
		
			&:first-child::before {
				right: -1px;
				left: auto;
				transform: rotate(180deg);
			}
		
			// Elements if width < 100%
			@if nth($separator-variant-lg,1) == "none" {
				&:before { display: none; }
			}
		
			// Triangle
			@else if nth($separator-variant-lg,1) == "triangle_icon" {
				&:before { clip-path: polygon(0 0, 0% 100%, 100% 50%); }
			}
		
			// Triangle invert
			@else if nth($separator-variant-lg,1) == "triangle-invert_icon" {
				&:before { clip-path: polygon(0 50%, 100% 100%, 0% 100%, 0 0, 100% 0); }
			}
		
			// Diagonal
			@else if nth($separator-variant-lg,1) == "diagonal_icon" {
				&:before { clip-path: polygon(0 0, 0% 100%, 100% 100%); }
			}
		
			// Diagonal invert
			@else if nth($separator-variant-lg,1) == "diagonal-invert_icon" {
				&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
			}
		}
	
		@media screen and(max-width: $breakpoint-md-max) {
			@if nth($width-md,1) == 100% or nth($width-md,1) == 100vw {
				&:before {
					width: 100%;
					left: 0;
					top: -1px;
					display: flex;
				
					@include media-constructor(height, $separator-width);
				}
			
				&:first-child::before {
					bottom: -1px;
					right: 0px;
					top: auto;
					transform: rotate(180deg);
				}
			
				// Elements if width == 100%
				@if nth($separator-variant-md,1) == "none" {
					&:before { display: none; }
				}
			
				// Triangle
				@else if nth($separator-variant-md,1) == "triangle_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 50% 100%); }
				}
			
				// Triangle invert
				@else if nth($separator-variant-md,1) == "triangle-invert_icon" {
					&:before { clip-path: polygon(100% 100%, 50% 0, 0% 100%, 0 0, 100% 0); }
				}
			
				// Diagonal
				@else if nth($separator-variant-md,1) == "diagonal_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
				}
			
				// Diagonal invert
				@else if nth($separator-variant-md,1) == "diagonal-invert_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 100% 100%); }
				}
			}
		
			@else  {
				&:before {
					left: -1px;
					top: 0;
					height: 100%;
					display: flex;
				
					@include media-constructor(width, $separator-width);
				}
			
				&:first-child::before {
					right: -1px;
					left: auto;
					transform: rotate(180deg);
				}
			
				// Elements if width < 100%
				@if nth($separator-variant-md,1) == "none" {
					&:before { display: none; }
				}
			
				// Triangle
				@else if nth($separator-variant-md,1) == "triangle_icon" {
					&:before { clip-path: polygon(0 0, 0% 100%, 100% 50%); }
				}
			
				// Triangle invert
				@else if nth($separator-variant-md,1) == "triangle-invert_icon" {
					&:before { clip-path: polygon(0 50%, 100% 100%, 0% 100%, 0 0, 100% 0); }
				}
			
				// Diagonal
				@else if nth($separator-variant-md,1) == "diagonal_icon" {
					&:before { clip-path: polygon(0 0, 0% 100%, 100% 100%); }
				}
			
				// Diagonal invert
				@else if nth($separator-variant-md,1) == "diagonal-invert_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
				}
			}
		}
	
		@media screen and (max-width: $breakpoint-xs-max) {
			@if nth($width-xs,1) == 100% or nth($width-xs,1) == 100vw {
				&:before {
					width: 100%;
					left: 0;
					top: -1px;
					display: flex;
				
					@include media-constructor(height, $separator-width);
				}
			
				&:first-child::before {
					bottom: -1px;
					top: auto;
					right: 0px;
					transform: rotate(180deg);
				}
			
				// Elements if width == 100%
				@if nth($separator-variant-xs,1) == "none" {
					&:before { display: none; }
				}
			
				// Triangle
				@else if nth($separator-variant-xs,1) == "triangle_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 50% 100%); }
				}
			
				// Triangle invert
				@else if nth($separator-variant-xs,1) == "triangle-invert_icon" {
					&:before { clip-path: polygon(100% 100%, 50% 0, 0% 100%, 0 0, 100% 0); }
				}
			
				// Diagonal
				@else if nth($separator-variant-xs,1) == "diagonal_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
				}
			
				// Diagonal invert
				@else if nth($separator-variant-xs,1) == "diagonal-invert_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 100% 100%); }
				}
			}
		
			@else  {
				&:before {
					left: -1px;
					top: 0;
					height: 100%;
					display: flex;
				
					@include media-constructor(width, $separator-width);
				}
			
				&:first-child::before {
					right: -1px;
					left: auto;
					transform: rotate(180deg);
				}
			
				// Elements if width < 100%
				@if nth($separator-variant-xs,1) == "none" {
					&:before { display: none; }
				}
			
				// Triangle
				@else if nth($separator-variant-xs,1) == "triangle_icon" {
					&:before { clip-path: polygon(0 0, 0% 100%, 100% 50%); }
				}
			
				// Triangle invert
				@else if nth($separator-variant-xs,1) == "triangle-invert_icon" {
					&:before { clip-path: polygon(0 50%, 100% 100%, 0% 100%, 0 0, 100% 0); }
				}
			
				// Diagonal
				@else if nth($separator-variant-xs,1) == "diagonal_icon" {
					&:before { clip-path: polygon(0 0, 0% 100%, 100% 100%); }
				}
			
				// Diagonal invert
				@else if nth($separator-variant-xs,1) == "diagonal-invert_icon" {
					&:before { clip-path: polygon(100% 0, 0 0, 0 100%); }
				}
			}
		}
	}
}

/**
* Footer Fulla
* Last Update: 2025-10-02T15:44:53+02:00
*     
* @Param("background", type="color-type-selector", group="container")
* @Param("box-background", type="color-type-selector", group="box")
* @Param("box-margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("border-style", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
* @Param("border-width", type="spacing", visibility={"border-style"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("border-color", type="color", visibility={"border-style"={"solid", "dashed", "dotted", "double"}}, group="box")
* @Param("border-radius", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
* @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
*/
@mixin footer-fulla-v2(
	$background: $color-primary, 
	$box-background: none, 
	$box-margin: 1rem null null, 
	$box-padding: 0rem, 
	$border-style: none, 
	$border-width: 1px, 
	$border-color: $color-secondary, 
	$border-radius: 0px, 
	$box-shadow-primary: none
) {
	//START
	$box-margin-lg: nth(inherit-list($box-margin),1);
	$box-margin-md: nth(inherit-list($box-margin),2);
	$box-margin-xs: nth(inherit-list($box-margin),3);

	//STOPP

	$background-check: first-color($background, $color-background);
	$box-background-check: first-color($box-background, $background-check);
	$text-color: preset-text-color($box-background-check);
	$headline-color: first-color($text-color,preset-text-color($box-background-check));
	$border-color: first-color($border-color,prioritize-color($background: $box-background-check));

	background: $background;

	&,
	a,
	a:hover { color: $text-color; }

	@include preset-headline-color($background-check);

	.footer-fulla-box {
		h1,
		.h1,
		h2,
		.h2,
		h3,
		.h3,
		h4,
		.h4,
		h5,
		.h5,
		h6,
		.h6 { color: $text-color; }
	
		background: $box-background;
		margin: calc(#{$box-margin-lg} / 2);
		flex: 1;
	
		@media screen and (max-width: $breakpoint-md-max) {
			margin: calc(#{$box-margin-md} / 2);
		}
	
		@media screen and (max-width: $breakpoint-xs-max) {
			margin: calc(#{$box-margin-xs} / 2);
		
			* { text-align: center; }
		}
	
		//Border
		@include media-constructor(border-width, $border-width);
	
		border: {
			style: $border-style;
			color: $border-color;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius);
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		>.inner {
			@include media-constructor(padding, $box-padding);
		}
	
		.ed-menu ul {
			margin: 0;
			padding: 0;
		
			li {
				display: inline-block;
				list-style: none;
				padding: 0;
				margin-right: 1rem;
			
				&:last-child { margin: 0; }
				&:before { display: none; }
			}
		
			@media screen and (max-width: $breakpoint-xs-max) {
				li { min-width: 100%; }
			}
		}
	}
}

