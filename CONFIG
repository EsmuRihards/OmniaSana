/**
 * Counter
 * Last Update: 2025-02-11T12:48:00+01:00
 *
 * @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")   
 * @Param("box-background", type="color", group="box")
 * @Param("box-padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
 * @Param("color-counter", type="color", group="content")
 * @Param("ff-counter", type="font", group="content")
 * @Param("fz-counter", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
 * @Param("counter-margin", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1, "separator"=1}, group="content")
 * @Param("color-caption", type="color", group="content")
 * @Param("ff-caption", type="font", group="content")
 * @Param("fz-caption", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="content")
 */
@mixin counter-v2(
	$columns: 4 2 1, 
	$grow: false, 
	$margin: 1rem, 
	$margin-horizontal: false, 
	$box-background: $gray-lightest, 
	$box-padding: 1.5rem, 
	$border-style-primary: none, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-secondary, 
	$border-radius-primary: 0, 
	$box-shadow-primary: none, 
	$color-counter: none, 
	$ff-counter: '', 
	$fz-counter: $fz-h2-all, 
	$counter-margin: (0rem 0rem 1rem 0rem, null, null), 
	$color-caption: none, 
	$ff-caption: '', 
	$fz-caption: 0.75rem
) {
	$box-background-check: first-color($box-background, $color-background);
	$text-color: preset-text-color($box-background-check);

	$color-counter: first-color($color-counter, preset-accent-color($box-background-check));
	$color-caption: first-color($color-caption, preset-text-color($box-background-check));

	//Row Settings
	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive:true
	);

	.counter-box {
		color: $text-color;
		background: $box-background;
		//Column Settings
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		//Background & Text Color
		@if type-of($box-background) == color and $box-background != none {
			background: $box-background;
		
			@include preset-headline-color($box-background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	
		//Box Padding
		> .inner {
			@include media-constructor(padding, $box-padding);
		}
	}

	.counter-content {
		@include media-constructor(font-size, $fz-counter);
	
		@if $ff-counter == '' { font-family: $ff-headlines; }
		@else  { font-family: $ff-counter; }
	
		position: relative;
		line-height: 1;
	
		@include media-constructor(margin, $counter-margin);
		@include media-constructor(max-width, extend-constructor('calc(100% - (',$counter-margin,') * 2)'));
	
		text-align: center;
		color: $color-counter;
		font-weight: bold;
	
		.small {
			@include media-constructor(font-size, $fz-caption);
		}
	}

	.counter-caption {
		line-height: 1;
	
		@if $ff-caption == '' { font-family: $ff-headlines; }
		@else  { font-family: $ff-caption; }
	
		@include media-constructor(font-size, $fz-caption);
	
		text-transform: uppercase;
		color: $color-caption;
	}
}

