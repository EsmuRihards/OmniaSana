@mixin gallery-v3(
	$columns: 5 5 2, 
	$grow: false, 
	$margin: (2rem, null, 1rem), 
	$margin-horizontal: false, 
	$justify-content: flex-start-gallery, 
	$style: default, 
	$grid-columns: 4, 
	$horizontal-position: flex-center-gallery, 
	$vertical-position: vertical_center, 
	$hover-style: fade, 
	$hover-background: $color-primary, 
	$hover-color: $none, 
	$cover-all: true, 
	$hover-width: auto, 
	$captions-align: left, 
	$captions-position: bottom-left, 
	$hover-duration: 0.5s, 
	$hover-opacity: 70%, 
	$hover-scale: 110%, 
	$hover-rotate: 6deg, 
	$captions-padding: 1rem, 
	$captions-font: link-default-font, 
	$gallery-reverse: false, 
	$border-style-primary: none, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-primary, 
	$border-radius-primary: 0px, 
	$box-shadow-primary: none
) {
	$margin-lg: nth(inherit-list($margin),1);
	$margin-md: nth(inherit-list($margin),2);

	$columns-lg: nth(inherit-list($columns),1);

	$grid-columns-lg: nth(inherit-list($grid-columns),1);
	$grid-columns-md: nth(inherit-list($grid-columns),2);
	$grid-columns-xs: nth(inherit-list($grid-columns),3);

	$justify-content-lg: nth(inherit-list($justify-content),1);
	$justify-content-md: nth(inherit-list($justify-content),2);
	$justify-content-xs: nth(inherit-list($justify-content),3);

	$hover-rotate: inherit-list($hover-rotate);
	$hover-rotate: (
																			    rotate(#{strip-units(nth($hover-rotate,1))}deg)
																			    rotate(#{strip-units(nth($hover-rotate,2))}deg)
																			    rotate(#{strip-units(nth($hover-rotate,3))}deg)
																		    );
	$hover-scale: inherit-list($hover-scale);
	$hover-scale: (
																			    scale(nth($hover-scale,1)/100%)
																			    scale(nth($hover-scale,2)/100%)
																			    scale(nth($hover-scale,3)/100%)
																		    );
	$hover-color: first-color($hover-color, preset-text-color($hover-background));

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive: true
	);

	.ed-gallery-items {
		display: flex;
		flex-direction: if($gallery-reverse,row-reverse,row);
		flex-wrap: if($gallery-reverse,wrap-reverse,wrap);
		//Need Justify because it's not possible to set to element
		@if $justify-content-lg == "flex-start-gallery" { justify-content: flex-start; }
		@else if $justify-content-lg == "flex-end-gallery" { justify-content: flex-end; }
		@else if $justify-content-lg == "flex-center-gallery" { justify-content: center; }
	
		@media screen and(max-width: $breakpoint-md-max) {
			@if $justify-content-md == "flex-start-gallery" { justify-content: flex-start; }
			@else if $justify-content-md == "flex-end-gallery" { justify-content: flex-end; }
			@else if $justify-content-md == "flex-center-gallery" { justify-content: center; }
		}
	
		@media screen and(max-width: $breakpoint-xs-max) {
			@if $justify-content-xs == "flex-start-gallery" { justify-content: flex-start; }
			@else if $justify-content-xs == "flex-end-gallery" { justify-content: flex-end; }
			@else if $justify-content-xs == "flex-center-gallery" { justify-content: center; }
		}
	
		> li {
			width: auto !important;
			float: none;
		
			@include media-constructor(margin, extend-constructor('calc(',$margin,' / 2) !important'));
			@include flex-grid-column(
				$margin: $margin, 
				$grow: $grow, 
				$columns: $columns
			);
		
			// because IE11 cant do flex and box-sizing border-box at the same time apply max width 
			@media screen and (-ms-high-contrast:active),(-ms-high-contrast:none) and (min-width: $breakpoint-md) {
				flex-grow: 0;
				max-width: if(nth($margin-lg,1)!=0, calc(#{100% / $columns-lg} - 2 * #{$margin-lg}), #{100%/$columns-lg});
			}
		
			//Border
			@include media-constructor(border-width, $border-width-primary);
		
			border: {
				style: $border-style-primary;
				color: $border-color-primary;
			}
		
			//Border Radius
			@include media-constructor(border-radius, $border-radius-primary);
		
			//Box Shadow
			@include media-constructor(box-shadow, $box-shadow-primary);
		}
	
		a {
			position: relative;
			//needs "block" because Safari can't handle "flex" and lightbox
			display: block;
			//Border Radius
			@include media-constructor(border-radius, $border-radius-primary);
		}
	
		// Grid Gallery
		@if $style == grid or $style == grid-reverse or $style == grid-dense {
			$grid-size-lg: floor(nth($grid-columns-lg,1)/2);
			$grid-size-md: floor(nth($grid-columns-md,1)/2);
			$grid-items-lg: if($grid-size-lg < 2, 3, ($grid-size-lg * $grid-size-lg) + 1);
			$grid-items-md: if($grid-size-md < 2, 3, ($grid-size-md * $grid-size-md) + 1);
			$grid-first-lg: if($style == grid, 1, $grid-size-lg + 1);
			$grid-first-md: if($style == grid, 1, $grid-size-md + 1);
			$grid-end-lg: if($style == grid, $grid-items-lg + $grid-first-lg + $grid-size-lg, $grid-items-lg + $grid-first-lg - $grid-size-lg);
			$grid-end-md: if($style == grid, $grid-items-md + $grid-first-md + $grid-size-md, $grid-items-md + $grid-first-md - $grid-size-md);
		
			@supports (display: grid) {
				display: grid;
				grid-auto-flow: dense;
			
				.ed-gallery-thumb {
					@if $style == grid-dense {
						&:nth-child(3n+1) {
							grid-column: span 2 / auto;
							grid-row: auto / span 2;
						}
					}
				}
			
				@media screen and (min-width: $breakpoint-md) {
					grid-template-columns: repeat(#{$grid-columns-lg}, 1fr);
					grid-template-rows: repeat(#{max($grid-size-lg, 2)}, 1fr);
				
					.ed-gallery-thumb {
						@if $style != grid-dense {
							&:nth-child(#{2*$grid-items-lg}n+#{$grid-first-lg}),
							&:nth-child(#{2*$grid-items-lg}n+#{$grid-end-lg}) {
								grid-column: span #{max($grid-size-lg, 2)} / auto;
								grid-row: auto / span #{max($grid-size-lg, 2)};
							}
						}
					}
				}
			
				@media screen and (max-width: $breakpoint-md-max) {
					grid-template-columns: repeat(#{$grid-columns-md}, 1fr);
					grid-template-rows: repeat(#{max($grid-size-md, 2)}, 1fr);
				
					.ed-gallery-thumb {
						@if $style != grid-dense {
							&:nth-child(#{2*$grid-items-md}n+#{$grid-first-md}),
							&:nth-child(#{2*$grid-items-md}n+#{$grid-end-md}) {
								grid-column: span #{max($grid-size-md, 2)} / auto;
								grid-row: auto / span #{max($grid-size-md, 2)};
							}
						}
					}
				}
			
				@media screen and (max-width: $breakpoint-xs-max) {
					display: flex;
				}
			}
		}
	
		// Collage 
		@if $style == collage {
			$position-map: (
																																			        flex-start-gallery: left,
																																			        flex-center-gallery: center,
																																			        flex-end-gallery: right,
																																			        vertical_top: top,
																																			        vertical_center: center,
																																			        vertical_bottom: bottom
																																			    );
		
			$horizontal-position: inherit-list($horizontal-position);
			$horizontal-position: (
																																	        	    map-get($position-map, nth($horizontal-position,1))
																																	        	    map-get($position-map, nth($horizontal-position,2))
																																	        	    map-get($position-map, nth($horizontal-position,3))
																																	        	);
		
			$vertical-position: inherit-list($vertical-position);
			$vertical-position: (
																																			        map-get($position-map, nth($vertical-position,1))
																																			        map-get($position-map, nth($vertical-position,2))
																																			        map-get($position-map, nth($vertical-position,3))
																																			    );
		
			@supports (object-fit: cover) {
				@media screen and (min-width: $breakpoint-xs) {
					> li {
						width: auto !important;
						height: 25vw;
					
						a {
							//important necessary to overwrite display block
							display: flex !important;
							height: 100%;
							position: relative;
						}
					
						img {
							object-fit: cover;
						
							@include media-constructor(object-position, zip($vertical-position, $horizontal-position));
						}
					}
				}
				@media screen and (min-width: $breakpoint-xs) and (max-width:$breakpoint-md-max) {
					> li {
						flex-basis: if($margin-md != 0, calc(35% - 2 * (#{$margin-md} /2)), 35%);
						margin: calc($margin-md /2) !important;
					
						&:nth-child(4n),
						&:nth-child(4n+1) { flex-basis: if($margin-md != 0, calc(65% - 2 * (#{$margin-md} /2)), 65%); }
					}
				}
				@media screen and (min-width: $breakpoint-md) {
					> li {
						flex-basis: if($margin-lg != 0, calc(35% - 2 * (#{$margin-lg} /2)), 35%);
						margin: calc($margin-lg /2) !important;
					
						&:nth-child(4n),
						&:nth-child(4n+1) { flex-basis: if($margin-lg != 0, calc(65% - 2 * (#{$margin-lg} /2)), 65%); }
					}
				}
			}
		}
	
		// Hover effects
		@if $hover-style == rotate {
			> li {
				overflow: hidden;
			
				a { background: $hover-background; }
			
				img {
					transition: $hover-duration;
					transition-property: opacity, transform;
				
					@include media-constructor(opacity, $hover-opacity);
				
					&:hover {
						@include media-constructor(transform, zip($hover-rotate, $hover-scale));
					
						opacity: 1;
					}
				}
			}
		}
		@else if $hover-style == zoom {
			> li {
				overflow: hidden;
			
				a {
					background: $hover-background;
					overflow: hidden;
				
					&:after {
						transform: translate(-50%, -140%);
						transition: $hover-duration;
						transition-property: opacity, transform;
						opacity: 0;
						font-family: fontawesome;
						color: $hover-color;
					
						@include media-constructor(font-size, extend-constructor('calc(2.5*',$fz-base-all,')'));
					
						display: block;
						position: absolute;
						left: 50%;
						top: 50%;
						content: "\f06e";
						pointer-events: none;
					}
				
					&:hover:after {
						transform: translate(-50%, -50%);
						opacity: 1;
					}
				}
			
				img {
					transition: $hover-duration;
					transition-property: opacity, transform;
					opacity: 1;
				
					&:hover {
						@include media-constructor(opacity, $hover-opacity);
						@include media-constructor(transform, $hover-scale);
					}
				}
			}
		}
	
		@else if $hover-style == fade {
			img {
				transition: $hover-duration;
				transition-property: opacity;
			}
		
			&:hover {
				img {
					@include media-constructor(opacity, $hover-opacity);
				
					&:hover { opacity: 1; }
				}
			}
		}
	
		@else if $hover-style == captions {
			a {
				transition: $hover-duration;
				transition-property: color;
			
				&::before {
					@include fake-element;
				
					transition: $hover-duration;
					transition-property: opacity;
					opacity: 0;
				}
			
				&::after {
					transition: $hover-duration;
					transition-property: opacity;
					opacity: 0;
					content: attr(title);
					position: absolute;
					color: $hover-color;
				
					@include media-constructor(line-height, $lh-all);
					@include media-constructor(padding, $captions-padding);
				
					@if type-of($hover-background) == color { background: $hover-background; }
					@if $captions-font == "link-special-font" { font-family: $ff-headlines; }
					@else  { font-family: $font-default; }
				
					@if $cover-all {
						width: 100%;
						height: 100%;
						top: 0;
						left: 0;
						display: flex;
						justify-content: center;
						align-items: center;
					}
				
					@else  {
						display: block;
					
						@include media-constructor(text-align, $captions-align);
						@include media-constructor(width, $hover-width);
					
						@if $captions-position == "centered" {
							top: 50%;
							left: 50%;
							transform: translate(-50%,-50%);
						}
					
						@else if $captions-position == "top-right" {
							top: 0;
							right: 0;
						}
					
						@else if $captions-position == "top-left" {
							top: 0;
							left: 0;
						}
					
						@else if $captions-position == "bottom-right" {
							bottom: 0;
							right: 0;
						}
					
						@else if $captions-position == "bottom-left" {
							bottom: 0;
							left: 0;
						}
					}
				}
			
				&:hover {
					&::before,
					&::after { opacity: 1; }
				}
			}
		}
	}
}

/**
 * @Param("background", type="color-type-selector", group="box")
 * @Param("margin", type="number", options={"units"={"rem","px","%","vh","vw"}, "responsive"=1}, group="box")
 * @Param("margin-horizontal", type="bool", group="box")
 * @Param("box-padding", type="spacing", options={"units"={"rem","px","%","vh","vw"},"responsive"=1}, group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none","solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box")
 * @Param("image-width", type="number", options={"units"={"rem","px","%","vh","vw"}, "responsive"=1}, group="image")
 * @Param("border-style-secondary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="image")
 * @Param("border-width-secondary", type="spacing", visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="image")
 * @Param("border-color-secondary", type="color", visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, group="image")
 * @Param("border-radius-secondary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="image")
 * @Param("box-shadow-secondary", type="shadow", options={"responsive"=1}, group="image") 
 */
@mixin text-with-image-v4(
	$background: $none, 
	$margin: 2rem, 
	$margin-horizontal: false, 
	$box-padding: 0rem, 
	$border-style-primary: none, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-primary, 
	$border-radius-primary: 0px, 
	$box-shadow-primary: none, 
	$image-width: 50% null 100%, 
	$border-style-secondary: none, 
	$border-width-secondary: 1px, 
	$border-color-secondary: $color-primary, 
	$border-radius-secondary: 0px, 
	$box-shadow-secondary: none
) {
	//color
	$background-check: first-color($background,$color-background);
	$text-color: preset-text-color($background-check);

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive:true
	);

	.text-with-image-box {
		// As long as we don't have enough space to put both containers side by side keep a little margin between them
		@include media-constructor(margin, extend-constructor('calc(',$margin,' /2)'));
		@include media-constructor(padding, $box-padding);
	
		@if $background != 'none' and $background != 'transparent' {
			background: $background;
		
			@include preset-headline-color($background-check);
		
			&,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
		@include media-constructor(box-shadow, $box-shadow-primary);
	}

	.text-with-image-image {
		@include media-constructor(margin, extend-constructor('calc(',$margin,' /2)'));
		@include media-constructor(flex-basis, extend-constructor('calc(', $image-width, ' -'), extend-constructor('2*', $margin, ' /2)'));
	
		// Just to make sure that the image is always visible
		min-height: 100px;
		// IE10+ HACK
		@media screen and (-ms-high-contrast: active), (-ms-high-contrast: none) {
			overflow: hidden;
		}
	
		> .background .ed-image .background-image-holder {
			//Border
			@include media-constructor(border-width, $border-width-secondary);
		
			border: {
				style: $border-style-secondary;
				color: $border-color-secondary;
			}
		
			//Border Radius
			@include media-constructor(border-radius, $border-radius-secondary);
			@include media-constructor(box-shadow, $box-shadow-secondary);
		}
	}

	//Fixes the problem that the image is displayed even if invisible is set
	@media screen and(min-width: $breakpoint-md-max) {
		body:not(.edit) & .hide-lg { display: none; }
	}
	@media screen and(min-width: $breakpoint-sm-max) and  (max-width: $breakpoint-md-max) {
		body:not(.edit) & .hide-md { display: none; }
	}
	@media screen and(max-width: $breakpoint-sm-max) {
		body:not(.edit) & .hide-sm { display: none; }
	}
}

/**
 * Preset boxes
 * Last Update: 2025-02-11T12:31:04+01:00
 *
 * @Param("columns", type="choice", options={"choices"={"1", "2", "3", "4", "5", "6"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("grow", type="bool", visibility={"columns"={"2", "3", "4", "5", "6"}}, options={"responsive"=1}, group="layout")
 * @Param("margin", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="layout")
 * @Param("margin-horizontal", type="bool", group="layout")
 * @Param("icon-position", type="choice", options={"choices"={"default", "outside", "left_default", "right_default"}, "expanded"=1}, group="layout")
 * @Param("flex-direction", type="choice", visibility={"icon-position"={"left_default", "right_default"}}, options={"choices"={"row", "column"}, "responsive"=1, "expanded"=1}, group="layout")
 * @Param("box-background", type="color-type-selector", group="box")
 * @Param("padding", type="spacing", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-style-primary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="box")
 * @Param("border-width-primary", type="spacing", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("border-color-primary", type="color", visibility={"border-style-primary"={"solid", "dashed", "dotted", "double"}}, group="box")
 * @Param("border-radius-primary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="box")
 * @Param("box-shadow-primary", type="shadow", options={"responsive"=1}, group="box") 
 * @Param("icon-background", type="color-type-selector", group="icon")
 * @Param("icon-color", type="color", group="icon")
 * @Param("fz-icon", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("icon-padding", type="number", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("border-style-secondary", type="choice", options={"choices"={"none", "solid", "dashed", "dotted", "double"}, "expanded"=1}, group="icon")
 * @Param("border-width-secondary", type="spacing", visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, options={"units"={"px", "rem", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("border-color-secondary", type="color", visibility={"border-style-secondary"={"solid", "dashed", "dotted", "double"}}, group="icon")
 * @Param("border-radius-secondary", type="border-radius", options={"units"={"px", "rem", "%", "vh", "vw"}, "responsive"=1}, group="icon")
 * @Param("box-shadow-secondary", type="shadow", options={"responsive"=1}, group="icon") 
 */
@mixin boxes-v3(
	$columns: 3 null 1, 
	$grow: false, 
	$margin: 2rem, 
	$margin-horizontal: false, 
	$icon-position: default, 
	$flex-direction: row, 
	$box-background: $color-background, 
	$padding: 0rem, 
	$border-style-primary: none, 
	$border-width-primary: 1px, 
	$border-color-primary: $color-primary, 
	$border-radius-primary: 0px, 
	$box-shadow-primary: none, 
	$icon-background: none, 
	$icon-color: none, 
	$fz-icon: 2.5rem, 
	$icon-padding: 0rem, 
	$border-style-secondary: none, 
	$border-width-secondary: 1px, 
	$border-color-secondary: $color-secondary, 
	$border-radius-secondary: 0, 
	$box-shadow-secondary: none
) {
	//Color Contrast
	$box-background-check: first-color($box-background,$color-background);
	$text-color: preset-text-color($box-background-check);

	$icon-background-check: first-color($icon-background, $box-background, $color-background);
	$icon-color: first-color($icon-color, preset-accent-color($icon-background-check));

	@include flex-grid-row(
		$margin: $margin, 
		$margin-horizontal: $margin-horizontal, 
		$responsive: true
	);

	//ICON BOX
	.boxes-icon {
		@include media-constructor(padding, $icon-padding);
	
		//Icon
		svg {
			display: block;
			fill: $icon-color;
		
			@include media-constructor(height, $fz-icon);
			@include media-constructor(width, $fz-icon);
			@include media-constructor(line-height, $fz-icon);
		}
	
		//Background
		@if type-of($icon-background) == "color" { background: $icon-background; }
		@else if type-of($icon-background) != "color" and $icon-background != none { background: $icon-background; }
	
		//Border
		@include media-constructor(border-width, $border-width-secondary);
	
		border: {
			style: $border-style-secondary;
			color: $border-color-secondary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-secondary);
	
		//Box shadow
		@include media-constructor(box-shadow, $box-shadow-secondary);
	}

	//BOXEN
	> .inner > .boxes-box {
		//Column Settings
		@include flex-grid-column(
			$margin: $margin, 
			$grow: $grow, 
			$columns: $columns, 
			$max-width: true, 
			$ie: true
		);
	
		> .inner {
			@include media-constructor(padding, $padding);
		}
	
		//Background & Text Color
		@if $box-background != none {
			background: $box-background;
		
			@include preset-headline-color($box-background-check);
		
			&,
			.ed-text a,
			.ed-element:not(.ed-button) > a { color: $text-color; }
		}
	
		//Border
		@include media-constructor(border-width, $border-width-primary);
	
		border: {
			style: $border-style-primary;
			color: $border-color-primary;
		}
	
		//Border Radius
		@include media-constructor(border-radius, $border-radius-primary);
	
		//Box Shadow
		@include media-constructor(box-shadow, $box-shadow-primary);
	}

	// Position Default 
	@if nth($icon-position, 1) == "default" {
		// need Flex-Settings,  not depictable with CMS Settings yet
		> .inner > .boxes-box {
			text-align: center;
		
			> .inner {
				justify-content: center;
			
				@include media-constructor(padding, $padding);
			
				> .boxes-icon { flex: none; }
			}
		
			.boxes-icon {
				margin-top: 0px;
				order: 0;
			}
		
			.boxes-box-inner {
				flex-basis: 100%;
				padding: 0px;
			}
		}
	}

	// Position OUTSIDE 
	@else if nth($icon-position, 1) == "outside" {
		> .inner > .boxes-box {
			@include media-constructor(min-width, extend-constructor('calc((', $fz-icon, ' + '), extend-constructor('', $icon-padding, ')'), extend-constructor('', ' *2', ')'));
			@include media-constructor(margin-top, extend-constructor('calc(((', $fz-icon, ' + '), extend-constructor('', $icon-padding, ' *2'), extend-constructor(')', '/2)', ' +'), extend-constructor('', $margin, '/2 )'));
		
			text-align: center;
		
			> .inner {
				@include media-constructor(padding, $padding);
			}
		}
	
		.boxes-icon {
			@include media-constructor(margin-top, extend-constructor('calc(-1 *', '', '('), extend-constructor('(', $fz-icon, ' +'), extend-constructor('2*', $icon-padding, ' + '), extend-constructor('2* ', nth($padding,1), ') /2 ))'));
		
			align-self: center;
			flex: none;
			justify-content: center;
			order: 0;
		}
	
		.boxes-box-inner {
			flex-basis: 100%;
			padding: 0px;
		}
	}

	// Position LEFT & RIGHT 
	@else if nth($icon-position,1) == "left_default" or nth($icon-position,1) == "right_default" {
		> .inner > .boxes-box {
			min-width: auto;
		
			@include media-constructor(margin-top, extend-constructor('calc(',$margin,' / 2)'));
		
			> .inner {
				@include media-constructor(flex-direction, $flex-direction);
			
				background-color: transparent;
				align-content: stretch;
				align-items: stretch;
				justify-content: center;
				padding: 0;
				//SAFARI + CHROME FIX ONLY- necessary because Safari needs the height defined
				@media screen and (-webkit-min-device-pixel-ratio:0) {
					height: 100%;
				
					.boxes-icon { align-items: center; }
				}
			}
		}
	
		.boxes-icon {
			margin-top: 0px;
		
			@include media-constructor(flex-basis, extend-constructor('calc(', $fz-icon, ' + '), extend-constructor('', $icon-padding, '*2 )'));
		
			height: 100%;
			display: flex;
			align-items: center;
			align-content: center;
			justify-content: center;
			align-self: auto;
			order: 0;
		
			@if nth($icon-position,1) == "right_default" { order: 2; }
		}
	
		.boxes-box-inner {
			flex: 1;
		
			@include media-constructor(padding, $padding);
		}
	}
}

/**
